---
// src/components/BentoGrid.astro
---
<section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <!-- Fondos decorativos sutiles para profundidad -->
    <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-gradient-to-bl from-accent/5 to-transparent blur-3xl -z-10"></div>
    <div class="absolute bottom-0 left-0 w-1/4 h-1/4 bg-gradient-to-tr from-primary/5 to-transparent blur-3xl -z-10"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Bento Grid Blueprint -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 h-auto">
            
            <!-- A. EL BLOQUE MAESTRO: Enfermería Domiciliaria (2/3 de ancho) -->
            <div class="md:col-span-2 relative rounded-[40px] overflow-hidden bg-white shadow-[0px_20px_50px_rgba(0,40,100,0.1)] min-h-[600px] flex flex-col md:flex-row group border border-[#e6e6e6]/50">
                
                <!-- Columna de Contenido (Texto) -->
                <div class="w-full md:w-[42%] p-8 md:p-12 flex flex-col justify-center relative z-20 bg-white">
                    <div class="inline-flex items-center gap-2 mb-6 text-accent">
                        <span class="w-8 h-[2px] bg-accent"></span>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Servicio Maestro</span>
                    </div>
                    
                    <h3 class="text-3xl md:text-4xl font-heading font-black text-[#0b3164] leading-tight mb-6">
                        Enfermería Domiciliaria <span class="text-accent text-5xl">.</span>
                    </h3>
                    
                    <p class="text-base md:text-lg text-[#061a36]/70 font-body leading-relaxed mb-10">
                        Delegue el cuidado complejo en manos expertas. Desde curaciones avanzadas hasta el monitoreo clínico las 24 horas del día con talento de élite.
                    </p>

                    <div class="flex flex-col gap-4">
                        <div class="flex items-center text-[#0b3164] font-bold text-sm">
                            <svg class="w-5 h-5 mr-3 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            Atención Clínica Permanente
                        </div>
                        <div class="flex items-center text-[#0b3164] font-bold text-sm">
                            <svg class="w-5 h-5 mr-3 text-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                            Protocolos Médicos Hospitalarios
                        </div>
                    </div>

                    <div class="mt-12">
                        <a 
                            href="/servicios/enfermeria-domiciliaria/" 
                            class="inline-flex items-center gap-3 text-secondary font-black text-sm uppercase tracking-widest border-b-2 border-accent pb-1 hover:gap-5 transition-all"
                        >
                            Ver Detalles Internos ➔
                        </a>
                    </div>
                </div>

                <!-- Columna Visual (Imagen) -->
                <div class="w-full md:w-[58%] relative min-h-[400px] md:min-h-full overflow-hidden">
                    <img 
                        src="/Enfermería%20Domiciliaria.webp" 
                        alt="Enfermera profesional brindando atención domiciliaria de élite" 
                        class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-105 transition-transform duration-1000"
                    />
                    <!-- Overlay sutil para integrar con el blanco de la izquierda -->
                    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/10 to-transparent hidden md:block"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent md:hidden"></div>
                </div>
            </div>

            <!-- BLOQUES SECUNDARIOS (Columna de la Derecha) -->
            <div class="md:col-span-1 flex flex-col gap-6 md:gap-8">
                
                <!-- B. Bloque Superior Derecho: Terapias de Recuperación -->
                <div class="relative flex-1 bg-white rounded-[32px] shadow-[0px_20px_40px_rgba(0,40,100,0.08)] p-8 md:p-10 flex flex-col justify-between overflow-hidden group border border-[#e6e6e6]/50 min-h-[280px]">
                    <div class="relative z-10">
                        <h4 class="text-2xl font-heading font-bold text-[#104892] mb-3">Terapias de Recuperación</h4>
                        <p class="text-[#061a36]/70 font-body text-sm leading-relaxed mb-6">Fisioterapia ocupacional y masajes clínicos para restaurar la alegría de vivir.</p>
                        
                        <a href="/servicios/terapias-recuperacion/" class="inline-flex items-center text-[#155ec0] font-bold hover:gap-2 transition-all group/link" aria-label="Ver más sobre terapias">
                            Explorar Terapias <span class="ml-2 text-xl group-hover/link:translate-x-1 transition-transform">➔</span>
                        </a>
                    </div>
                    
                    <div class="absolute -right-6 -bottom-6 md:-right-8 md:-bottom-8 w-36 h-36 md:w-44 md:h-44 rounded-full overflow-hidden border-4 border-white shadow-xl group-hover:scale-110 transition-transform duration-500">
                        <img 
                            src="https://images.unsplash.com/photo-1519823551278-64ac92734fb1?q=80&w=800&auto=format" 
                            alt="Sesión de masaje terapéutico" 
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>

                <!-- C. Bloque Inferior Derecho: Fisioterapia y Rehabilitación -->
                <div class="relative flex-1 bg-gradient-to-br from-[#f0f7ff] to-white rounded-[32px] shadow-[0px_20px_40px_rgba(0,40,100,0.08)] p-8 md:p-10 pb-10 flex flex-col items-start group border border-[#e6e6e6]/50 min-h-[300px]">
                    <div class="relative z-10 mb-6">
                        <div class="inline-flex items-center bg-white px-3 py-1 rounded-full text-[10px] font-bold text-accent uppercase tracking-widest border border-accent/10 mb-4 shadow-sm">
                            Vivir con Vitalidad
                        </div>
                        <h4 class="text-2xl font-heading font-bold text-[#0b3164] mb-3">Fisioterapia y Rehabilitación</h4>
                        <p class="text-[#061a36]/70 font-body text-sm leading-relaxed">Ejercicios de fuerza y movilidad adaptados para mantener la independencia.</p>
                    </div>

                    <div class="mt-auto w-full flex justify-between items-center relative z-10">
                         <a href="/servicios/fisioterapia-rehabilitacion/" class="btn-brand px-6 md:px-8 py-3 group/btn w-auto">
                            <span class="text-sm font-bold">Ver Programa</span>
                            <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                        
                        <div class="w-12 h-12 md:w-16 md:h-16 text-primary/20 pointer-events-none">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                            </svg>
                        </div>
                    </div>
                    
                    <div class="absolute -right-8 -top-8 p-4 opacity-[0.04] rotate-12 pointer-events-none">
                        <svg class="w-40 h-40 md:w-48 md:h-48 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zM11 7h2v6h-2V7zm0 8h2v2h-2v-2z"/></svg>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>
