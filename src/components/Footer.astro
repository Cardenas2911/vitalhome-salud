---
// src/components/Footer.astro
import FooterNewsletter from './ui/FooterNewsletter';
import FooterColumn from './ui/FooterColumn';
---

<footer class="bg-[#f8f9fa] pt-24 border-t border-[#e2e8f0]">
    <!-- El Newsletter está "fuera" del fondo oscuro para crear un efecto de capa superior -->
    <FooterNewsletter client:idle />
    
    <!-- Las columnas del footer sí van en el fondo oscuro -->
    <FooterColumn client:visible />
</footer>

