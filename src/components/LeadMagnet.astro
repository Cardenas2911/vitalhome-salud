---
// src/components/LeadMagnet.astro
---
<section id="contacto" class="py-24 bg-white relative overflow-hidden">
    <!-- Elementos decorativos de fondo -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 blur-[120px] rounded-full -z-10 animate-pulse"></div>
    <div class="absolute -bottom-24 -left-24 w-[400px] h-[400px] bg-accent/10 blur-[100px] rounded-full -z-10"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
            
            <!-- 1. Columna de Texto: Persuasión Crítica -->
            <div class="text-left">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-50 text-red-600 text-xs font-bold uppercase tracking-widest mb-8 border border-red-100/50">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-red-600"></span>
                    </span>
                    Atención Urgente
                </div>
                
                <h2 class="text-4xl md:text-5xl font-heading font-black text-[#0b3164] mb-8 leading-[1.15]">
                    ¿Necesita apoyo <span class="text-primary italic">urgente</span> con un adulto mayor?
                </h2>
                
                <p class="text-xl text-[#0b3164]/70 font-body mb-10 leading-relaxed">
                    No tome decisiones bajo estrés. Una enfermera jefe evaluará la situación clínica de su familiar y le propondrá un plan de acción en <strong class="text-secondary">menos de 24 horas</strong>, sin ningún compromiso.
                </p>

                <div class="space-y-6 mb-12">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center text-green-600 border border-green-100">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <span class="font-bold text-[#0b3164] text-lg">Respuesta garantizada &lt; 24h</span>
                    </div>
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-primary border border-blue-100">
                             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <span class="font-bold text-[#0b3164] text-lg">Confidencialidad Médica Total</span>
                    </div>
                </div>

                <div class="pt-8 border-t border-[#e6e6e6]">
                    <p class="text-sm text-[#0b3164]/40 font-bold uppercase tracking-[0.2em]">Respaldo Institucional VitalHome Salud</p>
                </div>
            </div>

            <!-- 2. Columna de Formulario: La Tarjeta Premium -->
            <div class="relative">
                <div class="absolute -inset-10 bg-primary/5 blur-[100px] rounded-full -z-10"></div>
                <div class="bg-white rounded-[40px] p-8 md:p-10 shadow-[0_48px_96px_-16px_rgba(0,0,0,0.12)] border border-[#e6e6e6]/50">
                    <h3 class="text-2xl font-heading font-bold text-secondary mb-8">Solicitar Evaluación Gratuita</h3>
                    
                    <form action="/contacto/formulario" method="GET" class="space-y-5">
                        <div class="space-y-2">
                            <label for="name" class="text-xs font-black uppercase tracking-widest text-[#0b3164]/40 ml-4">Nombre de contacto</label>
                            <input 
                                type="text" 
                                id="name" 
                                name="name" 
                                required 
                                class="w-full px-6 py-4 bg-slate-50 border border-[#e6e6e6] rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white transition-all text-secondary font-medium" 
                                placeholder="Ej: Maria Gonzalez"
                            >
                        </div>
                        <div class="space-y-2">
                            <label for="phone" class="text-xs font-black uppercase tracking-widest text-[#0b3164]/40 ml-4">Teléfono / WhatsApp</label>
                            <input 
                                type="tel" 
                                id="phone" 
                                name="phone" 
                                required 
                                class="w-full px-6 py-4 bg-slate-50 border border-[#e6e6e6] rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white transition-all text-secondary font-medium" 
                                placeholder="Ej: +56 9 1234 5678"
                            >
                        </div>
                        <div class="space-y-2 pb-4">
                            <label for="urgency" class="text-xs font-black uppercase tracking-widest text-[#0b3164]/40 ml-4">Nivel de Urgencia</label>
                            <select 
                                id="urgency" 
                                name="urgency" 
                                required 
                                class="w-full px-6 py-4 bg-slate-50 border border-[#e6e6e6] rounded-2xl focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white transition-all text-secondary font-medium appearance-none"
                            >
                                <option value="" disabled selected>Seleccione urgencia...</option>
                                <option value="inmediata">Atención Inmediata (24-48 hrs)</option>
                                <option value="esta-semana">Esta semana</option>
                                <option value="planificacion">Planificación futura</option>
                            </select>
                        </div>

                        <button 
                            type="submit" 
                            class="btn-brand w-full py-5 text-lg group"
                        >
                            <span class="relative z-10 flex items-center justify-center gap-3">
                                SOLICITAR EVALUACIÓN
                                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                                </svg>
                            </span>
                        </button>
                    </form>
                    
                    <div class="mt-8 flex items-center justify-center gap-2 opacity-60">
                        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Conexión Segura & Encriptada</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- JSON-LD AEO Injection: ContactPage & LocalBusiness -->
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ContactPage",
      "url": "https://www.vitalhomesalud.com/contacto/formulario",
      "name": "Solicitud de Evaluación Médica Urgente",
      "description": "Contacte a nuestras enfermeras jefes para recibir una evaluación clínica domiciliaria en menos de 24 horas."
    },
    {
      "@type": "LocalBusiness",
      "name": "VitalHome Salud",
      "image": "https://www.vitalhomesalud.com/images/logo-vitalhomesalud.png",
      "@id": "https://www.vitalhomesalud.com",
      "url": "https://www.vitalhomesalud.com",
      "telephone": "+573138050356",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Carrera 7",
        "addressLocality": "Bogotá",
        "addressRegion": "Bogotá D.C.",
        "postalCode": "110111",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.6097,
        "longitude": -74.0817
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday",
          "Sunday"
        ],
        "opens": "00:00",
        "closes": "23:59"
      }
    }
  ]
}
</script>
