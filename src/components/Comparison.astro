---
// src/components/Comparison.astro
---
<section class="py-24 bg-background-brand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16">
            <h2 class="text-3xl font-heading font-bold text-secondary sm:text-4xl">
                VitalHome Salud vs. El Enfoque Tradicional
            </h2>
            <p class="mt-4 text-lg text-text-brand/70 max-w-2xl mx-auto font-body">Decida sobre datos precisos. Así es como nuestra ingeniería de cuidado supera los estándares convencionales y las agencias genéricas.</p>
        </div>

        <div class="max-w-4xl mx-auto bg-surface-brand shadow-xl rounded-2xl overflow-hidden border border-zinc-200">
            <!-- Table Header -->
            <div class="grid grid-cols-3 bg-zinc-50 border-b border-zinc-200 p-6 items-center">
                <div class="col-span-1 text-sm font-bold text-secondary uppercase tracking-wider">Métrica de Cuidado</div>
                <div class="col-span-1 text-center font-bold text-zinc-500 text-sm uppercase">Agencia Tradicional</div>
                <div class="col-span-1 text-center font-bold text-primary text-sm uppercase rounded-md bg-blue-50 py-2 border border-blue-100">VitalHome Salud</div>
            </div>

            <!-- Row 1 -->
            <div class="grid grid-cols-3 border-b border-zinc-100 p-6 items-center hover:bg-zinc-50/50 transition-colors">
                <div class="col-span-1 font-medium text-text-brand">Supervisión Médica</div>
                <div class="col-span-1 flex justify-center text-zinc-400">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    <span class="sr-only">No</span>
                </div>
                <div class="col-span-1 flex items-center justify-center text-green-600 bg-green-50 py-1 px-3 rounded-full mx-auto font-medium text-sm">
                    <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Filtro Estricto 24/7
                </div>
            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-3 border-b border-zinc-100 p-6 items-center hover:bg-zinc-50/50 transition-colors">
                <div class="col-span-1 font-medium text-text-brand">Protocolos de Emergencia</div>
                <div class="col-span-1 flex justify-center text-zinc-500 text-sm">
                    Reacción Tardía
                </div>
                <div class="col-span-1 flex items-center justify-center text-green-600 font-medium text-sm">
                     <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Clínicamente Escalable
                </div>
            </div>

             <!-- Row 3 -->
            <div class="grid grid-cols-3 border-b border-zinc-100 p-6 items-center hover:bg-zinc-50/50 transition-colors">
                <div class="col-span-1 font-medium text-text-brand">Selección de Personal</div>
                <div class="col-span-1 flex justify-center text-zinc-500 text-sm">
                    Bolsa de Empleo
                </div>
                <div class="col-span-1 flex items-center justify-center text-green-600 font-medium text-sm">
                    <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Top 5% Vocacional
                </div>
            </div>
            
            <!-- Row 4 -->
            <div class="grid grid-cols-3 p-6 items-center hover:bg-zinc-50/50 transition-colors">
                <div class="col-span-1 font-medium text-text-brand">Metodología de Bienestar</div>
                <div class="col-span-1 flex justify-center text-zinc-400">
                     <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </div>
                <div class="col-span-1 flex items-center justify-center text-green-600 font-bold text-sm bg-green-50 py-1 px-3 rounded-full mx-auto">
                    <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    VitalCare® Pro
                </div>
            </div>
        </div>

    </div>
</section>
