---
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang="es" itemscope itemtype="http://schema.org/WebPage">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Seguridad de Respaldo para Hosting Estático (YMYL) -->
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.lordicon.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self';" />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		
		<!-- Favicons (AEO & Mobile App Optimization) -->
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
		<meta name="theme-color" content="#104892" />
		
		<meta name="generator" content={Astro.generator} />
		
		<!-- Componente AEO Centralizado -->
		<SEO />
		
		<!-- Fuentes (Outfit e Inter) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
		<meta name="robots" content="index, follow, max-image-preview:large" />
		
		<!-- Lordicon CDN -->
		<script src="https://cdn.lordicon.com/lordicon.js" is:inline></script>
	</head>
	<body class="antialiased" itemscope itemtype="http://schema.org/AboutPage">
		<main itemprop="mainContentOfPage" class="min-h-screen flex flex-col">
			<slot />
		</main>

		<!-- GLOBAL WHATSAPP BUTTON (Lujo Clínico) -->
		<div class="fixed bottom-4 right-4 md:bottom-8 md:right-8 z-[100] group">
			<a 
				href="https://wa.me/573138050356" 
				target="_blank" 
				rel="noopener noreferrer" 
				class="relative bg-[#25D366] text-white size-14 md:size-16 rounded-full shadow-[0_20px_40px_rgba(37,211,102,0.4)] flex items-center justify-center transition-all duration-500 hover:scale-110 hover:-translate-y-2"
				aria-label="Contactar por WhatsApp"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
					<path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
				</svg>

				<!-- Animación de "Pulso" Atrás -->
				<div class="absolute inset-0 bg-[#25D366] rounded-full -z-10 animate-ping opacity-30 group-hover:opacity-60 transition-opacity"></div>
			</a>
		</div>

	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
