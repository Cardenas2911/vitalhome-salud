---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  UserCheck, 
  Clock, 
  ArrowRight, 
  Star, 
  CheckCircle2,
  PhoneCall,
  Activity,
  HeartPulse,
  Syringe,
  ClipboardList,
  Plus
} from "lucide-react";

const pageTitle = "Enfermería Domiciliaria de Élite | VitalHome Salud";
const pageDescription = "Cuidado clínico profesional en su hogar. Enfermeras jefes verificadas, protocolos VitalHome Salud 24/7 y atención especializada para pacientes crónicos.";

const breadcrumbItems = [
  { label: "Servicios", href: "/servicios/" },
  { label: "Enfermería Domiciliaria", isCurrent: true }
];

const features = [
  {
    title: "Personal 100% Verificado",
    desc: "Riguroso proceso de selección clínica y antecedentes de seguridad.",
    icon: UserCheck
  },
  {
    title: "Monitoreo VitalHome Salud 24/7",
    desc: "Supervisión constante por enfermeras jefes para máxima tranquilidad.",
    icon: Activity
  },
  {
    title: "Continuidad del Cuidado",
    desc: "Evitamos la rotación excesiva para fortalecer el vínculo paciente-enfermero.",
    icon: HeartPulse
  }
];

const specializedProcedures = [
  "Administración de medicamentos IV/IM",
  "Curación de heridas complejas (Úlceras, post-quirúrgicas)",
  "Manejo de sondas y ostomías",
  "Toma de muestras de laboratorio",
  "Monitoreo de signos vitales avanzado",
  "Cuidados paliativos y del dolor"
];

const comparison = [
  { feature: "Verificación de Títulos", vital: true, informal: false },
  { feature: "Seguro de Responsabilidad Clínica", vital: true, informal: false },
  { feature: "Supervisión de Enfermera Jefe", vital: true, informal: false },
  { feature: "Disponibilidad 24/7 Garantizada", vital: true, informal: "Sujeto a disponibilidad" },
  { feature: "Protocolos Médicos Estándar", vital: true, informal: false }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <Header />

  <main class="w-full bg-[#ffffff] min-h-screen pt-32 md:pt-48 pb-0 overflow-hidden relative">
    
    {/* BREADCRUMBS OVER HERO */}
    <div class="absolute top-24 md:top-36 left-0 right-0 z-40">
        <div class="container mx-auto px-6">
            <Breadcrumbs client:load items={breadcrumbItems} />
        </div>
    </div>

    {/* SECCIÓN 1: HERO DE RIGOR CLÍNICO (ISLA DE AUTORIDAD) */}
    <section class="relative min-h-[70vh] flex items-center bg-transparent z-10 w-full pt-4 md:pt-10">
        
        {/* ✨ MANCHA MÍTICA AZUL CIAN ✨ */}
        <div class="absolute top-1/2 left-[20%] w-[800px] h-[800px] bg-[#155ec0]/15 blur-[120px] rounded-full -translate-y-1/2 -z-10 pointer-events-none"></div>
        
        {/* Decoración de fondo suave auxiliar */}
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#155ec0]/5 blur-[150px] rounded-full -z-20"></div>
        <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-[#f8f9fa] blur-[100px] rounded-full -z-20"></div>

        <div class="container mx-auto px-6 py-10 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                {/* Columna Izquierda: Mensaje de Autoridad */}
                <div class="lg:col-span-7 space-y-10">
                    <div class="space-y-6">
                        <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em] bg-blue-50 px-5 py-2 rounded-full border border-blue-100 inline-block">
                            Estandar de Lujo Clínico 2026
                        </span>
                        <h1 class="text-4xl md:text-7xl font-black text-[#061a36] leading-[1.1] font-heading">
                            Cuidado de Élite, <br/> <span class="text-[#155ec0]">Donde Más Se Necesita.</span>
                        </h1>
                        <p class="text-xl text-[#061a36]/70 font-medium leading-relaxed max-w-2xl">
                            Atención de enfermería profesional en la seguridad de su hogar. Implementamos protocolos clínicos de alta complejidad con el rigor de un entorno hospitalario y el calor de la familia.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-8 pt-4">
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <ShieldCheck className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">Verificado</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Respaldo Total</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <Activity className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">24/7</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Monitoreo VitalHome Salud</p>
                            </div>
                        </div>
                    </div>
                </div>

                {/* Columna Derecha: Isla de Autoridad Clínico Procedimental */}
                <div class="lg:col-span-5">
                    <div class="bg-[#155ec0] rounded-[40px] p-8 md:p-12 shadow-[0_40px_80px_rgba(21,94,192,0.3)] border border-white/10 relative group">
                        <div class="absolute -top-12 md:-top-6 -right-4 md:-right-6 size-20 md:size-24 bg-[#061a36] rounded-3xl flex items-center justify-center shadow-2xl rotate-12 group-hover:rotate-0 transition-transform">
                            <ClipboardList className="size-8 md:size-10 text-white" />
                        </div>

                        <h2 class="text-2xl font-black text-white font-heading mb-8 uppercase tracking-tight">Cápsula de Rigor Clínico</h2>
                        
                        <ul class="space-y-6 mb-12">
                            {[
                                { t: "Manejo de Terapia IV", d: "Administración segura de medicamentos endovenosos." },
                                { t: "Curación de Heridas", d: "Tratamiento avanzado de úlceras y post-quirúrgicos." },
                                { t: "Soporte Institucional", d: "Respaldo médico constante para casos de alta complejidad." }
                            ].map((item) => (
                                <li class="flex gap-4">
                                    <div class="mt-1">
                                        <div class="size-5 rounded-full bg-white/20 flex items-center justify-center">
                                            <div class="size-2 rounded-full bg-white"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <p class="text-white font-black text-sm">{item.t}</p>
                                        <p class="text-white/70 text-xs font-medium leading-relaxed">{item.d}</p>
                                    </div>
                                </li>
                            ))}
                        </ul>

                        <a 
                            href="/contacto/" 
                            class="block w-full bg-white text-[#155ec0] text-center py-6 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl hover:bg-[#061a36] hover:text-white transition-all duration-500 hover:-translate-y-1"
                        >
                            Agendar Valoración Médica
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* SECCIÓN 1: ¿POR QUÉ VITALHOME? (TRUST CARDS) */}
    <section class="py-24 container mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {features.map((f) => (
                <div class="bg-white p-10 rounded-[40px] border border-slate-100 shadow-sm hover:shadow-2xl transition-all duration-500 group">
                    <div class="size-14 rounded-2xl bg-blue-50 flex items-center justify-center mb-8 text-[#155ec0] group-hover:bg-[#155ec0] group-hover:text-white transition-all">
                        <f.icon className="size-8" />
                    </div>
                    <h3 class="text-xl font-black text-[#011633] font-heading mb-4">{f.title}</h3>
                    <p class="text-slate-500 text-sm font-medium leading-relaxed italic">{f.desc}</p>
                </div>
            ))}
        </div>
    </section>

    {/* SECCIÓN 2: PROCEDIMIENTOS ESPECIALIZADOS */}
    <section class="py-24 bg-white border-y border-slate-100 mb-20 overflow-hidden relative" id="procedimientos">
        <div class="container mx-auto px-6 flex flex-col lg:flex-row items-center gap-20">
            <div class="lg:w-1/2 space-y-10">
                <div class="space-y-4">
                    <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em] bg-blue-50 px-4 py-2 rounded-full border border-blue-100 w-fit">Rigor Profesional</span>
                    <h2 class="text-4xl md:text-5xl font-black text-[#011633] font-heading leading-tight">Más que compañía, <br/> <span class="text-[#155ec0]">intervención experta.</span></h2>
                </div>
                <p class="text-lg text-slate-500 font-medium leading-relaxed italic">
                    Contrario al cuidado informal, nuestro personal está facultado para realizar procedimientos médicos complejos con supervisión institucional permanente.
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {specializedProcedures.map((item) => (
                        <div class="flex items-center gap-3">
                            <CheckCircle2 className="size-5 text-[#155ec0] flex-shrink-0" />
                            <span class="text-xs font-bold text-[#011633] tracking-tight">{item}</span>
                        </div>
                    ))}
                </div>
            </div>
            
            <div class="lg:w-1/2 relative group">
                <div class="absolute inset-0 bg-[#155ec0] rounded-[60px] rotate-3 -z-10 opacity-10 group-hover:rotate-0 transition-transform duration-700"></div>
                <img 
                    src="/images/servicios/enfermeria_intervencion.png" 
                    alt="Procedimiento Médico Experto VitalHome Salud" 
                    class="rounded-[50px] shadow-3xl transform group-hover:-translate-y-4 transition-transform duration-700" 
                />
            </div>
        </div>
    </section>

    {/* SECCIÓN 3: TABLA DE SEGURIDAD (VITALHOME vs INFORMAL) */}
    <section class="py-32 bg-[#011633] overflow-hidden relative" id="seguridad">
        <div class="absolute top-0 right-0 w-96 h-96 bg-[#155ec0]/20 rounded-full blur-[120px]"></div>
        <div class="container mx-auto px-6 relative z-10">
            <div class="text-center mb-24 space-y-6">
                <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em]">Análisis de Riesgo</span>
                <h2 class="text-4xl md:text-6xl font-black text-white font-heading">El Valor de su <span class="text-[#155ec0]">Tranquilidad.</span></h2>
                <p class="text-blue-100/60 max-w-2xl mx-auto font-medium">No compare precios, compare protocolos de seguridad clínica.</p>
            </div>

            <div class="max-w-4xl mx-auto overflow-x-auto pb-6 scrollbar-hide">
                <div class="min-w-[600px] bg-white/5 backdrop-blur-md rounded-[40px] md:rounded-[50px] border border-white/10 overflow-hidden shadow-4xl m-1">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="border-b border-white/10 bg-white/5">
                                <th class="p-5 md:p-8 text-[10px] md:text-xs font-black text-white uppercase tracking-widest italic">Criterio de Seguridad</th>
                                <th class="p-5 md:p-8 text-[10px] md:text-xs font-black text-blue-400 uppercase tracking-widest text-center">VitalHome Salud</th>
                                <th class="p-5 md:p-8 text-[10px] md:text-xs font-black text-white/40 uppercase tracking-widest text-center">Independiente</th>
                            </tr>
                        </thead>
                        <tbody>
                            {comparison.map((row) => (
                                <tr class="border-b border-white/10 hover:bg-white/5 transition-colors">
                                    <td class="p-5 md:p-8 text-white font-medium text-xs md:text-sm">{row.feature}</td>
                                    <td class="p-5 md:p-8 text-center text-blue-400 font-black italic">✓ Garantizado</td>
                                    <td class="p-5 md:p-8 text-center text-white/30 text-[10px] md:text-xs font-bold uppercase tracking-tighter">No regulado</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    {/* SECCIÓN 4: RED DE SEGURIDAD (CTA FINAL) */}
    <section class="pb-32 container mx-auto px-6 mt-20">
        <div class="bg-[#011633] rounded-[60px] p-12 md:p-24 text-white text-center relative overflow-hidden group shadow-3xl">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-[#155ec0]/40 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#155ec0]/20 rounded-full blur-[120px]"></div>
            <div class="relative z-10 space-y-8">
                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-blue-400 bg-blue-400/10 px-5 py-2 rounded-full inline-block">Valoración Sin Costo</span>
                <h2 class="text-4xl md:text-6xl font-black text-white font-heading leading-tight">Su Familia Merece<br/>Tranquilidad Absoluta.</h2>
                <p class="text-lg text-white/60 font-medium max-w-2xl mx-auto leading-relaxed">
                    Agende una valoración clínica gratuita y descubra por qué más de 2.500 familias confían su cuidado a VitalHome Salud.
                </p>
                <div class="flex flex-col sm:flex-row gap-6 justify-center pt-4">
                    <a href="/contacto/" class="bg-[#155ec0] text-white px-12 py-7 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] shadow-[0_20px_50px_rgba(21,94,192,0.5)] hover:bg-white hover:text-[#011633] transition-all duration-500">
                        Agendar Valoración Clínica
                    </a>
                    <a 
                        href="https://wa.me/573138050356" 
                        target="_blank"
                        class="flex items-center gap-4 justify-center bg-white/5 border border-white/10 px-12 py-7 rounded-[2rem] font-black text-xs uppercase tracking-[0.2em] hover:bg-white/10 transition-all duration-500"
                    >
                        <PhoneCall className="size-5" /> Hablar con Especialista
                    </a>
                </div>
            </div>
        </div>
    </section>

  </main>
  <Footer />
</Layout>
