---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  CheckCircle2, 
  Heart, 
  Brain, 
  Users,
  MessageSquare,
  Smile,
  Lock,
  ArrowRight,
  ClipboardCheck,
  UserCheck,
  Activity,
  ChevronDown
} from "lucide-react";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud"
    },
    {
      "@type": "WebPage",
      "@id": "https://vitalhomesalud.com/servicios/apoyo-psicologico/#webpage",
      "url": "https://vitalhomesalud.com/servicios/apoyo-psicologico/",
      "name": "Apoyo Psicológico y Bienestar Mental para Pacientes y Familias"
    },
    {
      "@type": "Service",
      "@id": "https://vitalhomesalud.com/servicios/apoyo-psicologico/#service",
      "name": "Apoyo Psicológico y Contención Emocional Domiciliaria",
      "description": "Consultas psicológicas presenciales y virtuales diseñadas para el paciente geriátrico o con limitaciones físicas, y para prevenir el agotamiento (Burnout) del núcleo familiar.",
      "provider": {
        "@id": "https://vitalhomesalud.com/#organization"
      },
      "serviceType": ["Psychological Support", "Mental Health Counseling", "Caregiver Support"],
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "4.6097",
          "longitude": "-74.0817"
        },
        "geoRadius": "50000"
      },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "COP",
        "price": "0",
        "description": "Valoración psicológica inicial para establecer un plan de bienestar emocional.",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://vitalhomesalud.com/servicios/apoyo-psicologico/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Las terapias son solo para el paciente o también para la familia?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nuestro enfoque es integral; brindamos apoyo terapéutico directo tanto al paciente como a los hijos y cuidadores que enfrentan altos niveles de estrés or burnout."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es necesario que el psicólogo vaya a la casa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ofrecemos total flexibilidad. Podemos realizar las sesiones presencialmente en su domicilio para mayor comodidad o mediante teleconsulta privada."
          }
        }
      ]
    }
  ]
};

const title = "Apoyo Psicológico y Bienestar Mental en Casa | VitalHome Salud";
const breadcrumbItems = [
  { label: "Servicios", href: "/servicios/" },
  { label: "Apoyo Psicológico", isCurrent: true }
];
---

<Layout title={title}>
  <Header />
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#ffffff] min-h-screen pt-48 pb-0 overflow-hidden relative font-inter text-[#061a36]">
    
    <!-- Miga de Pan (Breadcrumbs) SOBRE EL HERO -->
    <div class="absolute top-24 md:top-36 left-0 right-0 z-40">
        <div class="container mx-auto px-6">
            <Breadcrumbs client:load items={breadcrumbItems} />
        </div>
    </div>

    <!-- SECCIÓN 1: HERO DE CONTENCIÓN (ISLA DE AUTORIDAD) -->
    <section class="relative min-h-[70vh] flex items-center bg-transparent z-10 w-full pt-4 md:pt-10">
        
        {/* ✨ MANCHA MÍTICA AZUL CIAN ✨ */}
        <div class="absolute top-1/2 left-[20%] w-[800px] h-[800px] bg-[#155ec0]/15 blur-[120px] rounded-full -translate-y-1/2 -z-10 pointer-events-none"></div>
        
        {/* Decoración de fondo suave auxiliar */}
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#155ec0]/5 blur-[150px] rounded-full -z-20"></div>

        <div class="container mx-auto px-6 py-10 relative z-10 max-w-[1600px]">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                {/* Columna Izquierda: Mensaje de Autoridad */}
                <div class="lg:col-span-7 space-y-10">
                    <div class="space-y-6">
                        <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em] bg-blue-50 px-5 py-2 rounded-full border border-blue-100 inline-block">
                            Estandar de Lujo Clínico 2026
                        </span>
                        <h1 class="text-4xl md:text-7xl font-black text-[#061a36] leading-[1.1] font-heading">
                            Salud Emocional <br/> <span class="text-[#155ec0]">en Casa.</span>
                        </h1>
                        <p class="text-xl text-[#061a36]/70 font-medium leading-relaxed max-w-2xl">
                          El bienestar mental es un pilar fundamental de la salud integral. VitalHome Salud ofrece apoyo psicológico especializado a domicilio y telemedicina, diseñado tanto para el paciente como para prevenir el agotamiento de su núcleo familiar.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-8 pt-4">
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <Brain className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">Acompañamiento</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Respaldo Profesional</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <Users className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">Núcleo Familiar</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Cuidado Integral</p>
                            </div>
                        </div>
                    </div>
                </div>

                {/* Columna Derecha: Isla de Autoridad Clínica (CÁPSULA DE RIGOR) */}
                <div class="lg:col-span-12 xl:col-span-5">
                    <div class="bg-[#155ec0] rounded-[40px] p-8 md:p-12 shadow-[0_40px_80px_rgba(21,94,192,0.3)] border border-white/10 relative group mt-10 lg:mt-0">
                        <div class="absolute -top-6 -right-6 size-24 bg-[#061a36] rounded-3xl flex items-center justify-center shadow-2xl rotate-12 group-hover:rotate-0 transition-transform">
                            <Heart className="size-10 text-white" />
                        </div>

                        <h2 class="text-2xl font-black text-white font-heading mb-8 uppercase tracking-tight">Cápsula de Rigor Clínico</h2>
                        
                        <ul class="space-y-6 mb-12">
                            {[
                                { t: "Cuidado del Paciente", d: "Soporte emocional frente a diagnósticos crónicos." },
                                { t: "Apoyo al Cuidador", d: "Prevención del Burnout y fatiga emocional severa." },
                                { t: "Mediación Familiar", d: "Herramientas para fortalecer la resiliencia en casa." }
                            ].map((item) => (
                                <li class="flex gap-4">
                                    <div class="mt-1">
                                        <div class="size-5 rounded-full bg-white/20 flex items-center justify-center">
                                            <div class="size-2 rounded-full bg-white"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <p class="text-white font-black text-sm">{item.t}</p>
                                        <p class="text-white/70 text-xs font-medium leading-relaxed">{item.d}</p>
                                    </div>
                                </li>
                            ))}
                        </ul>

                        <a 
                            href="https://wa.me/573138050356" 
                            target="_blank"
                            class="block w-full bg-white text-[#155ec0] text-center py-6 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl hover:bg-[#061a36] hover:text-white transition-all duration-500 hover:-translate-y-1"
                        >
                            Hablar con la Coordinación
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2: ABORDAJE 360° (Bento Grid) -->
    <section class="py-24 lg:py-40 bg-[#f8f9fa] relative overflow-hidden">
      <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        <div class="text-center mb-24 space-y-4">
           <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Propuesta de Valor</span>
           <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">
            Un Espacio Seguro para Quien <br />
            <span class="text-[#155ec0]">Cuida y Quien es Cuidado.</span>
           </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 h-auto">
          <!-- Card de Paciente (Gande) -->
          <div class="md:col-span-2 bg-white rounded-[40px] p-10 md:p-16 border border-[#e2e8f0] hover:shadow-2xl transition-all group flex flex-col md:flex-row gap-12 items-center">
             <div class="flex-1 space-y-6">
                <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center group-hover:bg-[#155ec0] transition-colors">
                  <Heart className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
                </div>
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading">Para el Paciente</h3>
                <p class="text-slate-500 font-medium leading-relaxed text-lg">
                  Acompañamiento experto en la aceptación de diagnósticos complejos, pérdida de autonomía y gestión de la ansiedad. Fomentamos la resiliencia desde el primer encuentro.
                </p>
             </div>
             <div class="w-full md:w-1/2 h-64 bg-slate-100 rounded-[30px] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700 shadow-inner border border-slate-200">
               <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&q=80&w=800')] bg-cover bg-center"></div>
             </div>
          </div>

          <!-- Card de Familiar -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] hover:shadow-2xl transition-all group shrink-0">
             <div class="space-y-8">
                <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center group-hover:bg-[#155ec0] transition-colors">
                  <UserCheck className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
                </div>
                <h3 class="text-2xl font-black text-[#011633] font-heading">Familiar Responsable</h3>
                <p class="text-slate-500 font-medium leading-relaxed">
                  Estrategias de desahogo y manejo de la culpa para evitar el colapso emocional de quienes cuidan.
                </p>
                <div class="pt-4 border-t border-slate-100">
                  <p class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest italic leading-relaxed">"Usted también merece ser cuidado."</p>
                </div>
             </div>
          </div>

          <!-- Card de Modalidad Flex -->
          <div class="bg-[#061a36] rounded-[40px] p-10 group hover:shadow-2xl transition-all relative overflow-hidden">
             <div class="absolute -right-10 -bottom-10 size-40 bg-[#155ec0]/20 rounded-full blur-3xl"></div>
             <div class="space-y-6 relative z-10">
                <div class="size-14 rounded-2xl bg-[#155ec0] flex items-center justify-center">
                  <Activity className="size-7 text-white" />
                </div>
                <h3 class="text-xl font-black text-white font-heading">Modalidad Flexible</h3>
                <p class="text-slate-400 font-medium leading-relaxed">
                  Sesiones presenciales en la intimidad y reserva de su hogar, o vía teleconsulta estructurada y segura.
                </p>
             </div>
          </div>

          <!-- Card Testimonio Corto -->
          <div class="md:col-span-2 bg-[#155ec0] rounded-[40px] p-10 md:p-12 border border-white/10 group overflow-hidden relative">
             <div class="absolute right-0 top-0 h-full w-1/3 bg-white/5 skew-x-12"></div>
             <div class="flex flex-col md:flex-row items-center gap-10">
                <div class="space-y-4 flex-1">
                   <p class="text-2xl font-black text-white font-heading italic">"Entendieron el agotamiento que sentía sin juzgarme. Hoy puedo cuidar mejor porque yo estoy mejor."</p>
                   <p class="text-white/60 font-black text-[10px] uppercase tracking-[0.3em]">Hija de Paciente - Bogotá</p>
                </div>
                <div class="size-20 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-md">
                   <Heart className="size-10 text-white animate-pulse-slow" />
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: EL PUENTE DE AUTORIDAD (Micro-Glosario) -->
    <section class="py-24 lg:py-40 bg-white relative overflow-hidden">
      <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
           <div class="space-y-10">
              <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Glosario de Autoridad</span>
              <h2 class="text-4xl md:text-6xl font-black text-[#011633] font-heading leading-tight">
                Entendemos lo que su <br />
                <span class="text-[#155ec0]">Familia está Viviendo.</span>
              </h2>
              <p class="text-lg text-slate-500 font-medium leading-relaxed max-w-xl">
                La salud mental en el entorno domiciliario tiene términos específicos que pocas instituciones abordan con rigor clínico. Le ayudamos a identificar estas señales para actuar a tiempo.
              </p>
           </div>

           <div class="grid grid-cols-1 gap-8">
              <!-- Item Glosario 1 -->
              <div class="bg-[#f8f9fa] rounded-[40px] p-10 border border-[#e2e8f0] relative group hover:border-[#155ec0] transition-all">
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <h4 class="text-2xl font-black text-[#011633] font-heading">Burnout del Cuidador</h4>
                    <span class="text-[#155ec0] font-black text-[10px] uppercase bg-blue-50 px-3 py-1 rounded-full border border-blue-100">Estado Clínico</span>
                  </div>
                  <p class="text-slate-500 font-medium leading-relaxed">
                    Estado de agotamiento físico y emocional severo. En VitalHome Salud, no solo cuidamos al paciente; le brindamos a usted el soporte psicológico necesario para recuperar su propio bienestar.
                  </p>
                  <a href="/recursos/glosario/" class="inline-flex items-center gap-2 text-[#155ec0] font-black text-xs uppercase tracking-widest hover:gap-4 transition-all">
                    Ver en el Glosario <ArrowRight className="size-4" />
                  </a>
                </div>
              </div>

              <!-- Item Glosario 2 -->
              <div class="bg-[#f8f9fa] rounded-[40px] p-10 border border-[#e2e8f0] relative group hover:border-[#155ec0] transition-all">
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <h4 class="text-2xl font-black text-[#011633] font-heading">Labilidad Emocional</h4>
                    <span class="text-[#155ec0] font-black text-[10px] uppercase bg-blue-50 px-3 py-1 rounded-full border border-blue-100">Identificación</span>
                  </div>
                  <p class="text-slate-500 font-medium leading-relaxed">
                    Cambios rápidos en el estado de ánimo, comunes en demencias o post-operatorios. Brindamos contención experta, creando un entorno de calma constante para evitar crisis familiares.
                  </p>
                  <a href="/recursos/glosario/" class="inline-flex items-center gap-2 text-[#155ec0] font-black text-xs uppercase tracking-widest hover:gap-4 transition-all">
                    Ver en el Glosario <ArrowRight className="size-4" />
                  </a>
                </div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 4: LA RED DE SEGURIDAD (FAQ) -->
    <section class="py-24 lg:py-40 bg-[#eceef0] relative overflow-hidden">
      <div class="max-w-4xl mx-auto px-4 md:px-8">
        <div class="text-center mb-24 space-y-4">
           <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Resolución de Dudas</span>
           <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">
            Soporte Psicológico: <br />
            <span class="text-[#155ec0]">Respuestas Profesionales.</span>
           </h2>
        </div>

        <div class="space-y-6">
          <!-- FAQ Item 1 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Las terapias son solo para el paciente o también para la familia?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Nuestro enfoque es integral; brindamos apoyo terapéutico directo tanto al paciente como a los hijos y cuidadores que enfrentan altos niveles de estrés o burnout. Entendemos que la salud de uno afecta a todos.
              </div>
            </div>
          </div>

          <!-- FAQ Item 2 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Es necesario que el psicólogo vaya a la casa?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Ofrecemos total flexibilidad. Podemos realizar las sesiones presencialmente en su domicilio para mayor comodidad y privacidad, o mediante teleconsulta privada si así lo prefiere el paciente o la familia.
              </div>
            </div>
          </div>

          <!-- FAQ Item 3 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Qué pasa si el paciente se niega a recibir terapia?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Nuestros profesionales están entrenados en mediación geriátrica. Iniciamos con un enfoque de "compañía clínica y escucha activa" para ganar la confianza del adulto mayor gradualmente, sin generar la presión de una terapia convencional.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 5: FOOTER DE CONVERSIÓN (Z-Pattern) -->
    <section class="py-24 lg:py-40 bg-[#061a36] relative overflow-hidden">
      <div class="absolute -left-20 top-0 size-96 bg-[#155ec0]/10 rounded-full blur-[120px]"></div>
      
      <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-center">
           
           <!-- Lado Izquierdo: Testimonio y Autoridad -->
           <div class="space-y-12">
              <div class="space-y-8">
                 <div class="size-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                    <Smile className="size-10 text-[#155ec0]" />
                 </div>
                 <blockquote class="text-3xl md:text-5xl font-black text-white font-heading leading-tight italic">
                  "Poder hablar con alguien que entiende lo difícil que es cuidar a mi madre con Alzheimer me salvó de colapsar emocionalmente."
                 </blockquote>
                 <p class="text-slate-400 font-black text-xs uppercase tracking-[0.4em]">— Hija y Cuidadora Responsable</p>
              </div>

              <div class="flex items-center gap-8">
                 <div class="flex -space-x-4">
                    <div class="size-14 rounded-full border-4 border-[#061a36] bg-slate-200 overflow-hidden">
                       <img src="https://images.unsplash.com/photo-1559839734-2b71f1536783?auto=format&fit=crop&q=80&w=200" alt="Psicóloga" class="w-full h-full object-cover" />
                    </div>
                    <div class="size-14 rounded-full border-4 border-[#061a36] bg-[#155ec0] flex items-center justify-center">
                       <ShieldCheck className="size-7 text-white" />
                    </div>
                 </div>
                 <div>
                    <p class="text-white font-black text-sm uppercase tracking-wider">Red de Especialistas</p>
                    <p class="text-slate-400 text-xs font-semibold">Terapeutas en Bogotá y Chía</p>
                 </div>
              </div>
           </div>

           <!-- Lado Derecho: Formulario Minimalista (Isla Blanca) -->
           <div class="bg-white rounded-[40px] p-10 md:p-16 shadow-2xl relative border border-white/5">
              <div class="mb-10">
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading mb-4 italic">Coordinar Ayuda Profesional</h3>
                <p class="text-slate-500 font-medium">Reciba una primera escucha sin compromiso.</p>
              </div>

              <form method="POST" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Nombre</label>
                    <input type="text" name="nombre" placeholder="Ej: Maria Perez" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Teléfono</label>
                    <input type="tel" name="telefono" placeholder="313 000 0000" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Dirección de Residencia</label>
