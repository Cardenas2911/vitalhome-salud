---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <section class="bg-secondary text-white py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Rehabilitación en Casa</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 leading-tight">
          Rehabilitación Domiciliaria: Recuperación de la Movilidad y Autonomía en Casa.
        </h1>
        <p class="text-white/80 text-lg max-w-3xl mx-auto mb-10">
          Fisioterapeutas y terapeutas ocupacionales expertos crean <strong>planes personalizados</strong> de <strong>actividad física</strong>, <strong>ejercicios de resistencia</strong> y <strong>rehabilitación específica</strong> para restaurar la <strong>autonomía funcional</strong>.
        </p>
        <a href="/contacto/" class="inline-block bg-accent text-white font-semibold py-3 px-8 rounded-full hover:opacity-90 transition">
          Solicitar Plan de Rehabilitación
        </a>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
        {[
          { titulo: "Post-Cirugía y Caídas", desc: "Protocolo de recuperación seguro y progresivo para restaurar la movilidad tras intervenciones o accidentes." },
          { titulo: "Condiciones Crónicas", desc: "Programas adaptativos para artritis, Parkinson y otras condiciones que limitan la movilidad diaria." },
          { titulo: "Terapia Ocupacional", desc: "Reentrenamiento en actividades cotidianas para maximizar la independencia y calidad de vida." },
          { titulo: "Fortalecimiento Preventivo", desc: "Ejercicios de resistencia y equilibrio para prevenir caídas y deterioro funcional." },
        ].map(s => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <h2 class="text-lg font-bold text-primary font-heading mb-2">{s.titulo}</h2>
            <p class="text-gray-600 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
