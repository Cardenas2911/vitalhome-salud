---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  Activity, 
  Heart,
  Plus,
  MessageSquare,
  Accessibility,
  Zap,
  RotateCw,
  Waves,
  Sparkles,
  Bed
} from "lucide-react";

// Marcado JSON-LD Avanzado (@graph)
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud"
    },
    {
      "@type": "WebPage",
      "@id": "https://vitalhomesalud.com/servicios/terapias-recuperacion/#webpage",
      "url": "https://vitalhomesalud.com/servicios/terapias-recuperacion/",
      "name": "Terapias de Recuperación y Alivio del Dolor en Casa",
      "isPartOf": {
        "@id": "https://vitalhomesalud.com/#website"
      }
    },
    {
      "@type": "Service",
      "@id": "https://vitalhomesalud.com/servicios/terapias-recuperacion/#service",
      "name": "Servicio de Terapias y Masajes de Recuperación Domiciliaria",
      "description": "Intervenciones clínicas a domicilio incluyendo masajes descontracturantes, drenaje linfático y terapia ocupacional para adultos mayores, enfocados en el alivio del dolor crónico, reducción de edemas e independencia funcional.",
      "provider": {
        "@id": "https://vitalhomesalud.com/#organization"
      },
      "serviceType": ["Occupational Therapy", "Therapeutic Massage", "Lymphatic Drainage"],
      "audience": {
        "@type": "Audience",
        "audienceType": "Adultos mayores, pacientes con dolor crónico, edemas y movilidad reducida"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "4.6097",
          "longitude": "-74.0817"
        },
        "geoRadius": "50000"
      },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "COP",
        "price": "0",
        "description": "Valoración terapéutica inicial a domicilio para determinar el plan de alivio y recuperación adecuado.",
        "availability": "https://schema.org/InStock"
      }
    }
  ]
};

const title = "Terapias y Masajes de Recuperación Domiciliaria | VitalHome Salud";

const breadcrumbItems = [
  { label: "Nuestras Especialidades", href: "/servicios/" },
  { label: "Terapias y Masajes de Recuperación", isCurrent: true }
];
---

<Layout title={title}>
  <Header />
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#f8fafc] pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan (Breadcrumbs) Estándar -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-[500px] h-[500px] bg-blue-50/50 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- Sección 1: Hero de Alivio Clínico (Recuadro Azul) -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <!-- Columna Izquierda: Texto -->
          <div class="p-10 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Alivio y Recuperación
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading">
                Recuperación Funcional y Alivio: <span class="text-blue-400 text-glow">Libertad de Movimiento.</span>
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                Nuestras terapias manuales no son estéticas; son intervenciones clínicas a domicilio. Aliviamos el dolor articular, mejoramos la circulación y devolvemos el confort diario que su familiar necesita para descansar correctamente.
              </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 pt-4">
              <div class="bg-white/5 border border-white/10 rounded-3xl p-6 space-y-3 group hover:bg-blue-400/10 transition-colors text-center">
                <Sparkles className="mx-auto size-6 text-blue-400" />
                <p class="text-white font-bold text-xs uppercase tracking-widest">Alivio Dolor</p>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-3xl p-6 space-y-3 group hover:bg-blue-400/10 transition-colors text-center">
                <Waves className="mx-auto size-6 text-blue-400" />
                <p class="text-white font-bold text-xs uppercase tracking-widest">Reducción Edemas</p>
              </div>
              <div class="bg-white/5 border border-white/10 rounded-3xl p-6 space-y-3 group hover:bg-blue-400/10 transition-colors text-center">
                <Bed className="mx-auto size-6 text-blue-400" />
                <p class="text-white font-bold text-xs uppercase tracking-widest">Mejora Sueño</p>
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Isla Clínica (Formulario) -->
          <div class="bg-white/5 lg:bg-transparent p-6 md:p-12 lg:p-20 flex flex-col justify-center">
            <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl relative z-10 border border-slate-100">
              <div class="mb-10 text-center">
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading mb-3">Valoración Terapéutica</h3>
                <p class="text-[#011633]/60 font-semibold text-sm italic">Recupere el confort de su ser querido hoy.</p>
              </div>

              <form class="space-y-6">
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Nombre del Familiar</label>
                  <input type="text" placeholder="Su nombre" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
                </div>

                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">WhatsApp / Teléfono</label>
                  <input type="tel" placeholder="+57 300 000 0000" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
                </div>

                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Tipo de Dolor / Condición</label>
                  <textarea rows="2" placeholder="Ej: Dolor lumbar crónico, piernas hinchadas..." class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none resize-none"></textarea>
                </div>

                <button type="submit" class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1">
                  Solicitar Valoración en Casa
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección 2: El Bento Grid Clínico (Intervenciones Específicas) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 pt-32 pb-16">
      <div class="text-center mb-24 space-y-4">
        <span class="text-[10px] font-black text-[#104892] uppercase tracking-[0.4em]">Tratamientos de Alivio</span>
        <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Intervenciones Especializadas <span class="text-[#155ec0]">para el Adulto Mayor.</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
        <!-- Card 1: Masaje Relajante -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
            <Heart className="size-8" />
          </div>
          <div class="flex-grow">
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Masaje Relajante Geriátrico</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Reducción clínica de la tensión muscular y agitación. Aplicamos movimientos biomecánicamente seguros que respetan la fragilidad ósea, logrando una mejora drástica en la calidad del sueño.
            </p>
          </div>
        </div>

        <!-- Card 2: Drenaje Linfático -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
            <Waves className="size-8" />
          </div>
          <div class="flex-grow">
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Drenaje Linfático y Circulatorio</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Tratamiento especializado para la retención de líquidos y edemas. Disminuimos la inflamación y eliminamos la sensación de "piernas pesadas", previniendo úlceras por inmovilidad.
            </p>
          </div>
        </div>

        <!-- Card 3: Terapia Ocupacional -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
            <Accessibility className="size-8" />
          </div>
          <div class="flex-grow">
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Terapia Ocupacional Adaptativa</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Entrenamiento en habilidades diarias (vestirse, comer, aseo) y adaptaciones del entorno para maximizar la independencia del paciente dentro del hogar.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección 3: Destructor de Objeciones (Rigor y Seguridad) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40 bg-[#eceef0] rounded-[80px]">
      <div class="max-w-4xl mx-auto text-center space-y-12">
        <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading leading-tight italic">Terapeutas Certificados, No Masajistas de Spa.</h2>
        <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
          El cuerpo de un adulto mayor requiere un trato extremadamente cuidadoso. Nuestros especialistas evalúan contraindicaciones como trombosis o heridas abiertas antes de cada sesión, adaptando cada movimiento a los diagnósticos preexistentes.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
           <div class="flex items-center gap-3 bg-white px-8 py-5 rounded-3xl border border-slate-200">
             <ShieldCheck className="size-5 text-[#155ec0]" />
             <span class="text-[#011633] font-black text-xs uppercase tracking-widest leading-none">Seguridad Clínica</span>
           </div>
           <div class="flex items-center gap-3 bg-white px-8 py-5 rounded-3xl border border-slate-200">
             <Activity className="size-5 text-[#155ec0]" />
             <span class="text-[#011633] font-black text-xs uppercase tracking-widest leading-none">Enfoque Geriátrico</span>
           </div>
        </div>
      </div>
    </section>

    <!-- Sección 4: Footer de Conversión (Z-Pattern) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <!-- Testimonio (Z-Pattern Left) -->
        <div class="space-y-12">
          <blockquote class="text-3xl md:text-5xl font-black text-[#104892] font-heading leading-tight italic">
            "Ver a mi madre dormir la noche entera sin quejarse de dolor en las piernas no tiene precio. El alivio llegó por fin a nuestra casa."
          </blockquote>
          <div class="flex items-center gap-4">
             <div class="size-14 rounded-full bg-[#155ec0] border-2 border-white shadow-lg flex items-center justify-center">
                <Heart className="size-8 text-white" />
             </div>
             <div>
               <p class="text-[#011633] font-bold text-base">Familia Martínez</p>
               <p class="text-slate-500 font-bold text-[10px] uppercase tracking-widest">Alivio Comprobado</p>
             </div>
          </div>
        </div>

        <!-- Call to Action (Z-Pattern Right) -->
        <div class="flex justify-center lg:justify-end">
           <a 
            href="https://wa.me/573138050356" 
            target="_blank"
            class="bg-[#061a36] hover:bg-[#155ec0] text-white w-full max-w-md py-12 rounded-[40px] flex flex-col items-center justify-center gap-5 transition-all duration-500 shadow-2xl group relative"
          >
             <MessageSquare className="size-12 group-hover:scale-110 transition-transform" />
             <div class="text-center space-y-2">
               <span class="block font-black text-2xl uppercase tracking-tighter">Agendar Visita de Alivio</span>
               <span class="block text-white/50 font-bold text-[10px] uppercase tracking-widest">Valoración Inicial en Casa</span>
             </div>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- CTA Sticky Flotante -->

</Layout>

<style>
  html { scroll-behavior: smooth; }
  .text-glow { text-shadow: 0 0 40px rgba(96, 165, 250, 0.4); }
</style>
