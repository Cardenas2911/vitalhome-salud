---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  Clock, 
  CheckCircle2, 
  Activity, 
  ArrowRight,
  ClipboardCheck,
  UserCheck,
  Heart,
  ChevronRight,
  Plus,
  MessageSquare,
  Eye,
  Calendar,
  FileText,
  Smartphone,
  ChevronDown
} from "lucide-react";

// Marcado JSON-LD Avanzado (@graph)
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud"
    },
    {
      "@type": "WebPage",
      "@id": "https://vitalhomesalud.com/servicios/gestion-monitoreo-salud/#webpage",
      "url": "https://vitalhomesalud.com/servicios/gestion-monitoreo-salud/",
      "name": "Acompañamiento y Gestión de Salud Domiciliaria",
      "isPartOf": {
        "@id": "https://vitalhomesalud.com/#website"
      }
    },
    {
      "@type": "Service",
      "@id": "https://vitalhomesalud.com/servicios/gestion-monitoreo-salud/#service",
      "name": "Servicio de Acompañamiento y Monitoreo de Salud 24/7",
      "description": "Supervisión clínica 24 horas liderada por enfermeras jefes, acompañamiento a citas médicas externas y control riguroso de la evolución del paciente.",
      "provider": {
        "@id": "https://vitalhomesalud.com/#organization"
      },
      "serviceType": "Health Monitoring and Care Management",
      "audience": {
        "@type": "Audience",
        "audienceType": "Pacientes crónicos, dependientes y familiares responsables"
      },
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "4.6097",
          "longitude": "-74.0817"
        },
        "geoRadius": "50000"
      },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "COP",
        "price": "0",
        "description": "Valoración clínica inicial gratuita para diseñar un plan de monitoreo a medida.",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://vitalhomesalud.com/servicios/gestion-monitoreo-salud/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cómo actúan ante una emergencia médica en la madrugada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Contamos con protocolos de emergencia estrictos. Nuestra coordinación clínica, liderada por una enfermera jefe, está disponible 24/7 vía WhatsApp y llamada directa para asistir, guiar y coordinar traslados de inmediato si la situación lo requiere."
          }
        },
        {
          "@type": "Question",
          "name": "¿El personal acompaña al paciente dentro de la cita médica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Nuestro servicio incluye el traslado logístico y el acompañamiento profesional dentro del consultorio. Nos aseguramos de recibir las instrucciones médicas exactas y reportárselas a usted en tiempo real."
          }
        }
      ]
    }
  ]
};

const title = "Monitoreo Clínico 24/7 y Acompañamiento Médico | VitalHome Salud";

const breadcrumbItems = [
  { label: "Servicios", href: "/servicios/" },
  { label: "Acompañamiento y Monitoreo 24/7", isCurrent: true }
];
---

<Layout title={title}>
  <Header />
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#f8fafc] pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan (Breadcrumbs) Estándar -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-[500px] h-[500px] bg-blue-50/50 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- Sección 1: Hero de Alivio Emocional (Recuadro Azul) -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <!-- Columna Izquierda: Texto -->
          <div class="p-10 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Gestión Clínica Predictiva
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading">
                Control y Paz Mental: <span class="text-blue-400 text-glow">Monitoreo Clínico 24/7.</span>
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                La tranquilidad de saber que su ser querido está siempre protegido es invaluable. Asumimos la gestión integral de su salud: desde el acompañamiento a citas externas hasta la supervisión clínica 24 horas. Usted recupere su tiempo, nosotros garantizamos el bienestar.
              </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
               <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <Eye className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Supervisión Continua</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <Activity className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Reportes Tiempo Real</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <ShieldCheck className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Cero Estrés Logístico</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <UserCheck className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Respaldo Profesional</span>
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Isla Clínica (Formulario) -->
          <div class="bg-white/5 lg:bg-transparent p-6 md:p-12 lg:p-20 flex flex-col justify-center">
            <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl relative z-10 border border-slate-100">
              <div class="mb-10 text-center">
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading mb-3">Solicitar Ayuda Experta</h3>
                <p class="text-[#011633]/60 font-semibold text-sm italic">Hable directamente con una Enfermera Jefe.</p>
              </div>

              <form class="space-y-6">
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Nombre Completo</label>
                  <input 
                    type="text" 
                    placeholder="Su nombre" 
                    class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all placeholder:text-slate-400"
                  />
                </div>

                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">WhatsApp / Teléfono</label>
                  <input 
                    type="tel" 
                    placeholder="+57 321 000 0000" 
                    class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all placeholder:text-slate-400"
                  />
                </div>

                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Condición del Paciente</label>
                  <textarea 
                    rows="3"
                    placeholder="Cuéntenos brevemente qué necesita gestionar..." 
                    class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all placeholder:text-slate-400 resize-none"
                  ></textarea>
                </div>

                <button 
                  type="submit" 
                  class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-3"
                >
                  Hablar con una Enfermera Jefe
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección 2: El Bento Grid Clínico (El Control Operativo) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 pt-32 pb-16">
      <div class="text-center mb-24 space-y-4">
        <span class="text-[10px] font-black text-[#104892] uppercase tracking-[0.4em]">Control Operativo</span>
        <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Gestión Integral en <span class="text-[#155ec0]">Manos Expertas.</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Item 1 -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex gap-8 items-start">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors">
            <Activity className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
          </div>
          <div>
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Supervisión Continua</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Control riguroso de constantes vitales y evolución del paciente las 24 horas, con protocolos de respuesta inmediata.
            </p>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex gap-8 items-start">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors">
            <Calendar className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
          </div>
          <div>
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Acompañamiento Médico Externo</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Traslado y apoyo logístico profesional en todas las citas clínicas, asegurando que el paciente nunca esté solo.
            </p>
          </div>
        </div>

        <!-- Item 3 -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex gap-8 items-start">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors">
            <FileText className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
          </div>
          <div>
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Control de Notas y Turnos</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Gestión estricta del personal de enfermería en casa y registro detallado de cada actividad clínica realizada.
            </p>
          </div>
        </div>

        <!-- Item 4 -->
        <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex gap-8 items-start">
          <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors">
            <Smartphone className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
          </div>
          <div>
            <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Reporte Inmediato</h4>
            <p class="text-slate-500 font-medium text-base leading-relaxed">
              Comunicación directa y transparente con la familia a través de canales digitales ante cualquier cambio en el estado de salud.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sección 3: Destructor de Objeciones (FAQ Emocional Interactiva) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40 bg-[#eceef0] rounded-[80px]">
      <div class="max-w-4xl mx-auto space-y-16">
        <div class="text-center space-y-4">
          <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">¿Cómo gestionamos las madrugadas y las urgencias?</h2>
          <p class="text-slate-600 font-bold text-lg">No hay intermediarios, usted habla directo con la coordinación clínica.</p>
        </div>

        <div class="space-y-4">
          <!-- Accordion 1 (Radio hack for simplicity in Astro without heavy JS) -->
          <details class="group bg-white rounded-[32px] border border-slate-200 overflow-hidden shadow-sm transition-all duration-500 open:shadow-xl open:border-[#155ec0]">
            <summary class="flex items-center justify-between p-8 cursor-pointer list-none font-black text-[#011633] tracking-tight text-xl uppercase">
              <span>Protocolo ante emergencias (3:00 AM)</span>
              <ChevronDown className="group-open:rotate-180 transition-transform duration-500 text-blue-500" />
            </summary>
            <div class="p-8 pt-0 text-slate-500 font-medium leading-relaxed border-t border-slate-50">
              Contamos con protocolos de emergencia estrictos. Nuestra coordinación clínica, liderada por una enfermera jefe, está disponible 24/7 vía WhatsApp y llamada directa para asistir, guiar y coordinar traslados de inmediato si la situación lo requiere.
            </div>
          </details>

          <!-- Accordion 2 -->
          <details class="group bg-white rounded-[32px] border border-slate-200 overflow-hidden shadow-sm transition-all duration-500 open:shadow-xl open:border-[#155ec0]">
            <summary class="flex items-center justify-between p-8 cursor-pointer list-none font-black text-[#011633] tracking-tight text-xl uppercase">
              <span>Soporte en Citas Médicas Externas</span>
              <ChevronDown className="group-open:rotate-180 transition-transform duration-500 text-blue-500" />
            </summary>
            <div class="p-8 pt-0 text-slate-500 font-medium leading-relaxed border-t border-slate-50">
              Usted no necesita pedir permisos laborales. Nuestro personal traslada al paciente, lo acompaña dentro del consultorio para recibir instrucciones profesionales y le entrega a usted un reporte técnico detallado al finalizar la jornada.
            </div>
          </details>

          <!-- Accordion 3 -->
          <details class="group bg-white rounded-[32px] border border-slate-200 overflow-hidden shadow-sm transition-all duration-500 open:shadow-xl open:border-[#155ec0]">
            <summary class="flex items-center justify-between p-8 cursor-pointer list-none font-black text-[#011633] tracking-tight text-xl uppercase">
              <span>Rotación y Control de Personal</span>
              <ChevronDown className="group-open:rotate-180 transition-transform duration-500 text-blue-500" />
            </summary>
            <div class="p-8 pt-0 text-slate-500 font-medium leading-relaxed border-t border-slate-50">
              Nosotros gestionamos los turnos, los reemplazos por enfermedad y la calidad del trato. Usted se enfoca en ser hijo, nieto o pareja; nosotros nos enfocamos en el rigor del cuidado profesional.
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- Sección 4: Footer de Conversión (Z-Pattern) -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <!-- Testimonio (Z-Pattern Left) -->
        <div class="space-y-12">
          <blockquote class="text-3xl md:text-5xl font-black text-[#104892] font-heading leading-tight italic">
            "Por fin pude dormir una noche completa. Saber que VitalHome tiene el control de la enfermería y las citas médicas de mi madre me devolvió la vida."
          </blockquote>
          <div class="flex items-center gap-4">
             <div class="size-14 rounded-full bg-[#155ec0] border-2 border-white shadow-lg flex items-center justify-center">
                <Heart className="size-8 text-white" />
             </div>
             <div>
               <p class="text-[#011633] font-bold text-base">Dra. Claudia Velez</p>
               <p class="text-slate-500 font-bold text-[10px] uppercase tracking-widest">Familiar de Paciente Cuidado por VitalHome</p>
             </div>
          </div>
        </div>

        <!-- Formulario (Z-Pattern Right) -->
        <div class="bg-white rounded-[60px] p-10 md:p-16 border border-[#e2e8f0] shadow-3xl">
           <div class="mb-10 text-center lg:text-left">
             <h3 class="text-3xl font-black text-[#011633] font-heading mb-3">Coordinar Plan de Monitoreo</h3>
             <p class="text-slate-500 font-semibold text-sm italic">Diseñaremos la logística clínica para que usted descanse.</p>
           </div>

           <form class="space-y-6">
              <div class="space-y-2">
                <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Nombre del Familiar Responsable</label>
                <input type="text" placeholder="Su nombre" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              </div>

              <div class="space-y-2">
                <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">WhatsApp de Contacto</label>
                <input type="tel" placeholder="+57 300 000 0000" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              </div>

              <button type="submit" class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1 mt-4">
                Coordinar Valoración Clínica Gratuita
              </button>
           </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <!-- CTA Sticky Flotante -->

</Layout>

<style>
  html { scroll-behavior: smooth; }
  .text-glow { text-shadow: 0 0 40px rgba(96, 165, 250, 0.4); }
  details summary::-webkit-details-marker { display: none; }
</style>
