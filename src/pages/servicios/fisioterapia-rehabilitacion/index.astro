---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  Activity, 
  ArrowRight,
  ClipboardCheck,
  UserCheck,
  Heart,
  Plus,
  Zap,
  RotateCw,
  Dumbbell,
  Undo2,
  ChevronDown,
  Target,
  Stethoscope
} from "lucide-react";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud"
    },
    {
      "@type": "WebPage",
      "@id": "https://vitalhomesalud.com/servicios/fisioterapia-rehabilitacion/#webpage",
      "url": "https://vitalhomesalud.com/servicios/fisioterapia-rehabilitacion/",
      "name": "Fisioterapia y Rehabilitación Física a Domicilio | VitalHome Salud"
    },
    {
      "@type": "Service",
      "@id": "https://vitalhomesalud.com/servicios/fisioterapia-rehabilitacion/#service",
      "name": "Fisioterapia y Rehabilitación Integral Domiciliaria",
      "description": "Terapia física especializada para la recuperación de movilidad, manejo de dolor crónico y rehabilitación neurológica o traumatológica directamente en la comodidad de su hogar.",
      "provider": {
        "@id": "https://vitalhomesalud.com/#organization"
      },
      "serviceType": ["Physical Therapy", "Rehabilitation", "Neurorehabilitation"],
      "areaServed": {
        "@type": "GeoCircle",
        "geoMidpoint": {
          "@type": "GeoCoordinates",
          "latitude": "4.6097",
          "longitude": "-74.0817"
        },
        "geoRadius": "50000"
      },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "COP",
        "price": "0",
        "description": "Valoración inicial por fisioterapeuta experto para diseñar un plan de rehabilitación a medida.",
        "availability": "https://schema.org/InStock"
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://vitalhomesalud.com/servicios/fisioterapia-rehabilitacion/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Tratan pacientes que han tenido un ACV (Derrame cerebral)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Contamos con fisioterapeutas especializados en neurorrehabilitación para trabajar en la recuperación de movilidad, equilibrio y funciones comprometidas tras un evento cerebrovascular."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito tener los equipos de terapia en casa?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Nuestros profesionales llevan el equipo portátil necesario (electroestimulación, bandas, pesas, etc.) para realizar una sesión de alta calidad clínica en su domicilio."
          }
        }
      ]
    }
  ]
};

const title = "Fisioterapia y Rehabilitación Física a Domicilio | VitalHome Salud";
const breadcrumbItems = [
  { label: "Servicios", href: "/servicios/" },
  { label: "Fisioterapia y Rehabilitación", isCurrent: true }
];
---

<Layout title={title}>
  <Header />
  
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#ffffff] min-h-screen pt-32 md:pt-48 pb-0 overflow-hidden relative font-inter text-[#061a36]">
    
    <!-- Miga de Pan (Breadcrumbs) SOBRE EL HERO -->
    <div class="absolute top-24 md:top-36 left-0 right-0 z-40">
        <div class="container mx-auto px-6">
            <Breadcrumbs client:load items={breadcrumbItems} />
        </div>
    </div>

    <!-- SECCIÓN 1: HERO FISIOTERAPIA (ISLA DE AUTORIDAD) -->
    <section class="relative min-h-[70vh] flex items-center bg-transparent z-10 w-full pt-4 md:pt-10">
        
        {/* ✨ MANCHA MÍTICA AZUL CIAN ✨ */}
        <div class="absolute top-1/2 left-[20%] w-[800px] h-[800px] bg-[#155ec0]/15 blur-[120px] rounded-full -translate-y-1/2 -z-10 pointer-events-none"></div>
        
        {/* Decoración de fondo suave auxiliar */}
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#155ec0]/5 blur-[150px] rounded-full -z-20"></div>

        <div class="container mx-auto px-6 py-10 relative z-10 max-w-[1600px]">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                
                {/* Columna Izquierda: Mensaje de Autoridad */}
                <div class="lg:col-span-7 space-y-10">
                    <div class="space-y-6">
                        <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em] bg-blue-50 px-5 py-2 rounded-full border border-blue-100 inline-block">
                            Rehabilitación de Alta Complejidad
                        </span>
                        <h1 class="text-4xl md:text-7xl font-black text-[#061a36] leading-[1.1] font-heading">
                            Recupere su Vida: <br/> <span class="text-[#155ec0]">Terapia en Casa.</span>
                        </h1>
                        <p class="text-xl text-[#061a36]/70 font-medium leading-relaxed max-w-2xl">
                          No permita que el dolor o la inmovilidad dicten su futuro. Nuestra fisioterapia domiciliaria elite combina rigor clínico con la comodidad de su hogar para acelerar su recuperación funcional.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-8 pt-4">
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <Activity className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">Movilidad</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Rango Funcional</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 group">
                            <div class="size-14 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center group-hover:bg-[#155ec0] transition-all">
                                <ShieldCheck className="size-6 text-[#155ec0] group-hover:text-white" />
                            </div>
                            <div>
                                <p class="text-[#061a36] font-black text-lg">Protocolo</p>
                                <p class="text-[#061a36]/40 text-[10px] uppercase tracking-widest font-bold">Seguridad Clínica</p>
                            </div>
                        </div>
                    </div>
                </div>

                {/* Columna Derecha: Isla de Autoridad Clínica (CÁPSULA DE RIGOR) --> */}
                <div class="lg:col-span-12 xl:col-span-5">
                    <div class="bg-[#155ec0] rounded-[40px] p-8 md:p-12 shadow-[0_40px_80px_rgba(21,94,192,0.3)] border border-white/10 relative group mt-10 lg:mt-0">
                        <div class="absolute -top-6 -right-6 size-24 bg-[#061a36] rounded-3xl flex items-center justify-center shadow-2xl rotate-12 group-hover:rotate-0 transition-transform">
                            <ClipboardCheck className="size-10 text-white" />
                        </div>

                        <h2 class="text-2xl font-black text-white font-heading mb-8 uppercase tracking-tight">Plan Terapéutico</h2>
                        
                        <ul class="space-y-6 mb-12">
                            {[
                                { t: "Diagnóstico Diferencial", d: "Identificación precisa de la causa raíz de la limitación." },
                                { t: "Tecnología Portátil", d: "Electroterapia y ultrasonido de grado clínico en casa." },
                                { t: "Seguimiento Élite", d: "Acompañamiento 1 a 1 sin distracciones clínicas." }
                            ].map((item) => (
                                <li class="flex gap-4">
                                    <div class="mt-1">
                                        <div class="size-5 rounded-full bg-white/20 flex items-center justify-center">
                                            <div class="size-2 rounded-full bg-white"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <p class="text-white font-black text-sm">{item.t}</p>
                                        <p class="text-white/70 text-xs font-medium leading-relaxed">{item.d}</p>
                                    </div>
                                </li>
                            ))}
                        </ul>

                        <a 
                            href="https://wa.me/573138050356" 
                            target="_blank"
                            class="block w-full bg-white text-[#155ec0] text-center py-6 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl hover:bg-[#061a36] hover:text-white transition-all duration-500 hover:-translate-y-1"
                        >
                            Agendar Valoración
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2: ECOSISTEMA DE RECUPERACIÓN (Bento Grid) -->
    <section class="py-24 lg:py-40 bg-[#f8f9fa] relative overflow-hidden">
      <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        <div class="text-center mb-24 space-y-4">
           <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Propuesta de Valor</span>
           <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">
            Ingeniería del Movimiento <br />
            <span class="text-[#155ec0]">para su Bienestar.</span>
           </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 h-auto">
          <!-- Card Neurorrehabilitación (Grande) -->
          <div class="md:col-span-2 bg-white rounded-[40px] p-10 md:p-16 border border-[#e2e8f0] hover:shadow-2xl transition-all group flex flex-col md:flex-row gap-12 items-center">
             <div class="flex-1 space-y-6">
                <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center group-hover:bg-[#155ec0] transition-colors">
                  <Stethoscope className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
                </div>
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading">Neurorrehabilitación</h3>
                <p class="text-slate-500 font-medium leading-relaxed text-lg">
                  Protocolos especializados para pacientes tras ACV, Parkinson o lesiones medulares. Enfoque en la plasticidad cerebral y recuperación de funciones cotidianas.
                </p>
             </div>
             <div class="w-full md:w-1/2 h-64 bg-slate-100 rounded-[30px] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700 shadow-inner border border-slate-200">
               <div class="w-full h-full bg-[url('https://images.unsplash.com/photo-1576765608535-5f04d1e3f289?auto=format&fit=crop&q=80&w=800')] bg-cover bg-center"></div>
             </div>
          </div>

          <!-- Card Traumatología -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] hover:shadow-2xl transition-all group shrink-0">
             <div class="space-y-8">
                <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center group-hover:bg-[#155ec0] transition-colors">
                  <RotateCw className="size-8 text-[#155ec0] group-hover:text-white transition-colors" />
                </div>
                <h3 class="text-2xl font-black text-[#011633] font-heading">Post-Quirúrgicos</h3>
                <p class="text-slate-500 font-medium leading-relaxed">
                  Recuperación acelerada tras cirugías de cadera, rodilla o columna con manejo de tejidos blandos y fortalecimiento.
                </p>
                <div class="pt-4 border-t border-slate-100 font-black text-[#155ec0] text-[10px] uppercase tracking-widest italic leading-relaxed">
                  "Menos tiempo en cama, más vida."
                </div>
             </div>
          </div>

          <!-- Card Manejo de Dolor -->
          <div class="bg-[#061a36] rounded-[40px] p-10 group hover:shadow-2xl transition-all relative overflow-hidden">
             <div class="absolute -right-10 -bottom-10 size-40 bg-[#155ec0]/20 rounded-full blur-3xl"></div>
             <div class="space-y-6 relative z-10">
                <div class="size-14 rounded-2xl bg-[#155ec0] flex items-center justify-center">
                  <Heart className="size-7 text-white" />
                </div>
                <h3 class="text-xl font-black text-white font-heading">Manejo de Dolor</h3>
                <p class="text-slate-400 font-medium leading-relaxed">
                  Terapias manuales e instrumentales para aliviar el dolor crónico y restaurar la calidad de vida del paciente.
                </p>
             </div>
          </div>

          <!-- Card Testimonio Corto -->
          <div class="md:col-span-2 bg-[#155ec0] rounded-[40px] p-10 md:p-12 border border-white/10 group overflow-hidden relative">
             <div class="absolute right-0 top-0 h-full w-1/3 bg-white/5 skew-x-12"></div>
             <div class="flex flex-col md:flex-row items-center gap-10">
                <div class="space-y-4 flex-1">
                   <p class="text-2xl font-black text-white font-heading italic">"Tras mi cirugía de rodilla, pensé que no volvería a caminar sin muletas. Con VitalHome, a las 4 semanas ya subía escaleras."</p>
                   <p class="text-white/60 font-black text-[10px] uppercase tracking-[0.3em]">Paciente de Ortopedia - Bogotá</p>
                </div>
                <div class="size-20 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-md">
                   <Undo2 className="size-10 text-white" />
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: EL PUENTE DE AUTORIDAD (Micro-Glosario Rehabilitación) -->
    <section class="py-24 lg:py-40 bg-white relative overflow-hidden">
      <div class="max-w-[1600px] mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">
           <div class="space-y-10">
              <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Base Científica</span>
              <h2 class="text-4xl md:text-6xl font-black text-[#011633] font-heading leading-tight">
                Terminología de <br />
                <span class="text-[#155ec0]">Alta Recuperación.</span>
              </h2>
              <p class="text-lg text-slate-500 font-medium leading-relaxed max-w-xl">
                Nuestro personal no solo aplica masajes; ejecuta planes de intervención clínica basados en la biomecánica y la neurociencia moderna.
              </p>
           </div>

           <div class="grid grid-cols-1 gap-8">
              <!-- Item Glosario 1 -->
              <div class="bg-[#f8f9fa] rounded-[40px] p-10 border border-[#e2e8f0] relative group hover:border-[#155ec0] transition-all">
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <h4 class="text-2xl font-black text-[#011633] font-heading">Hemiparesia</h4>
                    <span class="text-[#155ec0] font-black text-[10px] uppercase bg-blue-50 px-3 py-1 rounded-full border border-blue-100">Dato Clínico</span>
                  </div>
                  <p class="text-slate-500 font-medium leading-relaxed">
                    Debilidad de un lado del cuerpo tras un daño cerebral. Nuestra terapia se enfoca en la reeducación motriz y el fortalecimiento compensatorio.
                  </p>
                  <a href="/recursos/glosario/" class="inline-flex items-center gap-2 text-[#155ec0] font-black text-xs uppercase tracking-widest hover:gap-4 transition-all">
                    Ver en el Glosario <ArrowRight className="size-4" />
                  </a>
                </div>
              </div>

              <!-- Item Glosario 2 -->
              <div class="bg-[#f8f9fa] rounded-[40px] p-10 border border-[#e2e8f0] relative group hover:border-[#155ec0] transition-all">
                <div class="space-y-6">
                  <div class="flex items-center justify-between">
                    <h4 class="text-2xl font-black text-[#011633] font-heading">Espasticidad</h4>
                    <span class="text-[#155ec0] font-black text-[10px] uppercase bg-blue-50 px-3 py-1 rounded-full border border-blue-100">Tratamiento Técnico</span>
                  </div>
                  <p class="text-slate-500 font-medium leading-relaxed">
                    Aumento del tono muscular que provoca rigidez. Aplicamos técnicas de movilización pasiva y estiramiento activo para restaurar la fluidez del movimiento.
                  </p>
                  <a href="/recursos/glosario/" class="inline-flex items-center gap-2 text-[#155ec0] font-black text-xs uppercase tracking-widest hover:gap-4 transition-all">
                    Ver en el Glosario <ArrowRight className="size-4" />
                  </a>
                </div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 4: LA RED DE SEGURIDAD (FAQ Rehabilitación) -->
    <section class="py-24 lg:py-40 bg-[#eceef0] relative overflow-hidden">
      <div class="max-w-4xl mx-auto px-4 md:px-8">
        <div class="text-center mb-24 space-y-4">
           <span class="text-[10px] font-black text-[#155ec0] uppercase tracking-[0.4em]">Resolución de Dudas</span>
           <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">
            Terapia Confiable: <br />
            <span class="text-[#155ec0]">Respuestas con Rigor.</span>
           </h2>
        </div>

        <div class="space-y-6">
          <!-- FAQ Item 1 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Tratan pacientes que han tenido un ACV (Derrame cerebral)?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Sí. Contamos con fisioterapeutas especializados en neurorrehabilitación para trabajar en la recuperación de movilidad, equilibrio y funciones comprometidas tras un evento cerebrovascular, siempre en coordinación con su neurólogo de cabecera.
              </div>
            </div>
          </div>

          <!-- FAQ Item 2 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Cuánto duran las sesiones?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Las sesiones de fisioterapia domiciliaria tienen una duración de 45 a 60 minutos de trabajo efectivo 1 a 1, donde el terapeuta se enfoca exclusivamente en sus objetivos de recuperación.
              </div>
            </div>
          </div>

          <!-- FAQ Item 3 -->
          <div class="faq-item bg-white rounded-[30px] p-8 border border-white shadow-sm hover:shadow-md transition-shadow cursor-pointer">
            <div class="flex items-center justify-between gap-6 pointer-events-none">
              <h4 class="text-[#011633] font-black text-lg font-heading leading-tight italic">¿Llevan equipos como TENS o ultrasonido?</h4>
              <ChevronDown className="size-5 text-[#155ec0] shrink-0" />
            </div>
            <div class="max-h-0 overflow-hidden transition-all duration-500 ease-in-out faq-content pointer-events-none">
              <div class="pt-8 text-slate-500 font-medium leading-relaxed">
                Totalmente. Nuestros fisioterapeutas disponen de equipos portátiles de grado clínico (electroestimulación, ultrasonido terapéutico, etc.) para aplicar las mismas técnicas que encontraría en un centro de rehabilitación de primer nivel.
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 5: FOOTER DE CONVERSIÓN (Z-Pattern) -->
    <section class="py-24 lg:py-40 bg-[#061a36] relative overflow-hidden">
      <div class="absolute -left-20 top-0 size-96 bg-[#155ec0]/10 rounded-full blur-[120px]"></div>
      
      <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 lg:gap-32 items-center">
           
           <!-- Lado Izquierdo: Testimonio y Autoridad -->
           <div class="space-y-12">
              <div class="space-y-8">
                 <div class="size-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
                    <Undo2 className="size-10 text-[#155ec0]" />
                 </div>
                 <blockquote class="text-3xl md:text-5xl font-black text-white font-heading leading-tight italic">
                  "El hecho de no tener que trasladarme con dolor a una clínica hizo toda la diferencia en mi ánimo y mi recuperación."
                 </blockquote>
                 <p class="text-slate-400 font-black text-xs uppercase tracking-[0.4em]">— Paciente Post-Operado - Chía</p>
              </div>

              <div class="flex items-center gap-8">
                 <div class="flex -space-x-4">
                    <div class="size-14 rounded-full border-4 border-[#061a36] bg-slate-200 overflow-hidden">
                       <img src="https://images.unsplash.com/photo-1594824476967-48c8b964273f?auto=format&fit=crop&q=80&w=200" alt="Terapeuta" class="w-full h-full object-cover" />
                    </div>
                    <div class="size-14 rounded-full border-4 border-[#061a36] bg-[#155ec0] flex items-center justify-center">
                       <ShieldCheck className="size-7 text-white" />
                    </div>
                 </div>
                 <div>
                    <p class="text-white font-black text-sm uppercase tracking-wider">Expertos de Rehabilitación</p>
                    <p class="text-slate-400 text-xs font-semibold">Terapeutas en Bogotá y Sabana</p>
                 </div>
              </div>
           </div>

           <!-- Lado Derecho: Formulario Minimalista (Isla Blanca) -->
           <div class="bg-white rounded-[40px] p-10 md:p-16 shadow-2xl relative border border-white/5">
              <div class="mb-10">
                <h3 class="text-2xl md:text-3xl font-black text-[#011633] font-heading mb-4 italic">Agendar Valoración Física</h3>
                <p class="text-slate-500 font-medium">Inicie su proceso de recuperación en menos de 24 horas.</p>
              </div>

              <form class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Nombre Completo</label>
                    <input type="text" name="name" placeholder="Ej: Roberto Gomez" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
                  </div>
                  <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Teléfono / WhatsApp</label>
                    <input type="tel" name="phone" placeholder="313 000 0000" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Dirección de Residencia</label>
                  <input type="text" name="address" placeholder="Ej: Calle 127 # 7-10" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
                </div>
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Tipo de Patología</label>
                  <div class="relative">
                    <select name="pathology" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all appearance-none cursor-pointer">
                      <option value="" disabled selected>Seleccione Patología...</option>
                      <option value="diabetes">Diabetes / Hipertensión</option>
                      <option value="alzheimer">Alzheimer / Demencia</option>
                      <option value="post-operatorio">Recuperación Post-Operatoria</option>
                      <option value="respiratorio">Enfermedad Respiratoria</option>
                      <option value="paliativo">Cuidado Paliativo / Crónico</option>
                      <option value="movilidad">Limitación de Movilidad</option>
                      <option value="otros">Otras / Varias</option>
                    </select>
                    <ChevronDown className="absolute right-6 top-1/2 -translate-y-1/2 size-5 text-slate-400 pointer-events-none" />
                  </div>
                </div>
                <div class="space-y-2">
                  <label class="text-[10px] font-black text-[#011633] uppercase tracking-[0.2em] ml-2">Tipo de Rehabilitación</label>
                  <div class="relative">
                    <select name="rehab_type" required class="w-full bg-[#f8f9fa] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all appearance-none cursor-pointer">
                      <option value="" disabled selected>Seleccione Especialidad...</option>
                      <option value="post-operatoria">Post-Operatoria (Cadera/Rodilla/Columna)</option>
                      <option value="neurologica">Neurológica (ACV/Parkinson)</option>
                      <option value="dolor">Manejo de Dolor Crónico</option>
                      <option value="deportiva">Fisioterapia Deportiva</option>
                    </select>
                    <ChevronDown className="absolute right-6 top-1/2 -translate-y-1/2 size-5 text-slate-400 pointer-events-none" />
                  </div>
                </div>
                <button type="submit" class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.3em] py-6 rounded-2xl shadow-xl transition-all duration-500">
                  Solicitar Terapia Domiciliaria
                </button>
              </form>
           </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- Script para el FAQ Interactivo -->
  <script is:inline>
    document.querySelectorAll('.faq-item').forEach(item => {
      item.addEventListener('click', () => {
        const content = item.querySelector('.faq-content');
        const icon = item.querySelector('svg');
        const isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';

        // Cerrar todos los demás
        document.querySelectorAll('.faq-content').forEach(c => {
          c.style.maxHeight = '0px';
          c.parentElement.querySelector('svg').style.transform = 'rotate(0deg)';
        });

        // Abrir/Cerrar actual
        if (!isOpen) {
          content.style.maxHeight = content.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
        } else {
          content.style.maxHeight = '0px';
          icon.style.transform = 'rotate(0deg)';
        }
      });
    });
  </script>

</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
