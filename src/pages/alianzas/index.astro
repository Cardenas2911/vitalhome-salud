---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <section class="bg-primary text-white py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Red de Confianza</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 leading-tight">
          Nuestra Red de Confianza: Alianzas Estratégicas para un Cuidado Superior.
        </h1>
        <p class="text-white/80 text-lg max-w-3xl mx-auto mb-10">
          VitalHome Salud mantiene <strong>alianzas estratégicas</strong> con <strong>hospitales de prestigio</strong>, <strong>universidades líderes en ciencias de la salud</strong> y <strong>asociaciones profesionales</strong> que elevan nuestros estándares de atención.
        </p>
        <a href="/alianzas/colaboraciones/" class="inline-block bg-accent text-white font-semibold py-3 px-8 rounded-full hover:opacity-90 transition">
          Conocer Nuestros Aliados Estratégicos
        </a>
      </div>
    </section>

    <section class="py-16 px-6 bg-white">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
        <a href="/alianzas/colaboraciones/" class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:border-accent transition">
          <h2 class="text-xl font-bold text-primary font-heading mb-3">🤝 Alianzas y Colaboraciones</h2>
          <p class="text-gray-600">Hospitales, universidades y asociaciones que respaldan nuestra excelencia clínica.</p>
        </a>
        <a href="/alianzas/certificaciones/" class="bg-gray-50 rounded-2xl p-8 border border-gray-100 hover:border-accent transition">
          <h2 class="text-xl font-bold text-primary font-heading mb-3">🏅 Certificaciones y Acreditaciones</h2>
          <p class="text-gray-600">Sellos que avalan el cumplimiento de los estándares más rigurosos de la industria.</p>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
