---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <section class="bg-secondary text-white py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Calidad Certificada</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 leading-tight">
          Calidad Certificada: Nuestras Acreditaciones en Salud Domiciliaria Garantizan su Tranquilidad.
        </h1>
        <p class="text-white/80 text-lg max-w-3xl mx-auto">
          Resultado de <strong>auditorías externas</strong> y un <strong>compromiso constante</strong> con la mejora continua, nuestras certifaciones son la <strong>prueba institucional</strong> de que su ser querido está en las mejores manos.
        </p>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-6">
        {[
          { cert: "ISO 9001:2015", area: "Gestión de Calidad", desc: "Sistema de gestión de calidad implementado en todos los procesos operativos de atención domiciliaria." },
          { cert: "ACHS Certified", area: "Seguridad Clínica", desc: "Acreditación de la Asociación Chilena de Seguridad que valida nuestros protocolos de atención segura." },
          { cert: "HIPAA Compliance", area: "Privacidad de Datos", desc: "Cumplimiento total de las normativas internacionales de privacidad de información médica." },
          { cert: "Formación Continua", area: "Capacitación del Personal", desc: "Programa certificado de actualización periódica para todo el equipo clínico y de soporte." },
        ].map(c => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <span class="text-xs font-bold uppercase tracking-widest text-accent">{c.area}</span>
            <h2 class="text-xl font-bold text-primary font-heading mt-2 mb-3">🏅 {c.cert}</h2>
            <p class="text-gray-600 text-sm">{c.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-12 px-6 bg-gray-50 text-center">
      <a href="/contacto/" class="inline-block bg-primary text-white font-semibold py-3 px-8 rounded-full hover:opacity-90 transition">
        Ver Certificaciones de Calidad
      </a>
    </section>
  </main>
  <Footer />
</Layout>
