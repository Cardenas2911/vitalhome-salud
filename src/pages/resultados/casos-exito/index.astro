---
import Layout from "../../../layouts/Layout.astro";
import { ImpactMetrics } from "../../../components/results/ImpactMetrics";
import { CaseStudyCard } from "../../../components/results/CaseStudyCard";
import { ShieldCheck, ArrowRight, Star, Activity, Phone } from "lucide-react";

const pageTitle = "Resultados y Casos de Éxito | VitalHome Salud";
const pageDescription = "Explore nuestra evidencia clínica humana. Casos reales de recuperación y bienestar domiciliario que respaldan nuestra metodología VitalHome Salud.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main className="bg-[#f8f9fa]">
    {/* HERO SECTION - DARK TRUST */}
    <section className="relative pt-32 pb-20 lg:pt-48 lg:pb-32 bg-[#061a36] overflow-hidden">
      <div className="absolute inset-0 z-0">
        <div className="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2"></div>
        <div className="absolute bottom-0 left-0 w-[300px] h-[300px] bg-[#155ec0]/10 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/2"></div>
      </div>

      <div className="container mx-auto px-6 relative z-10">
        <div className="max-w-4xl mx-auto text-center space-y-8">
          <div className="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md animate-fade-in">
             <Star className="size-4 text-yellow-400 fill-yellow-400" />
             <span className="text-[10px] font-black text-white uppercase tracking-[0.2em]">Más de 500 familias atendidas</span>
          </div>
          
          <h1 className="text-5xl md:text-7xl font-black text-white font-heading leading-tight tracking-tight">
            Evidencia Humana de <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-blue-200">Bienestar Real.</span>
          </h1>
          
          <p className="text-blue-100/70 text-lg md:text-xl font-medium leading-relaxed max-w-2xl mx-auto italic">
            "No solo gestionamos diagnósticos; transformamos historias de vida. Descubra cómo nuestra metodología clínica recupera la salud y la paz en el hogar."
          </p>

          <div className="pt-8 flex flex-wrap justify-center gap-4">
             <div className="flex items-center gap-2 text-white/50 bg-white/5 px-6 py-3 rounded-2xl border border-white/5">
                <ShieldCheck className="size-5 text-blue-400" />
                <span className="text-xs font-bold uppercase tracking-widest">Protocolos Verificados</span>
             </div>
             <div className="flex items-center gap-2 text-white/50 bg-white/5 px-6 py-3 rounded-2xl border border-white/5">
                <Activity className="size-5 text-emerald-400" />
                <span className="text-xs font-bold uppercase tracking-widest">Monitoreo 24/7</span>
             </div>
          </div>
        </div>
      </div>
    </section>

    {/* METRICS SECTION */}
    <div className="container mx-auto px-6 -mt-16 relative z-20">
      <ImpactMetrics client:visible />
    </div>

    {/* CASES GRID */}
    <section className="py-24 container mx-auto px-6">
      <div className="max-w-3xl mb-20 space-y-4">
         <h2 className="text-4xl font-black text-[#011633] font-heading leading-tight">
           Historias que Respaldan <br />Su Elección.
         </h2>
         <div className="h-1.5 w-24 bg-[#155ec0] rounded-full"></div>
         <p className="text-slate-500 font-medium text-lg leading-relaxed pt-2">
            Seleccionamos tres casos representativos que ilustran nuestra capacidad de respuesta ante la complejidad clínica y emocional.
         </p>
      </div>

      <CaseStudyCard client:visible />
    </section>

    {/* FINAL CALL TO ACTION */}
    <section className="py-24 bg-[#061a36] relative overflow-hidden">
       <div className="container mx-auto px-6 text-center space-y-12 relative z-10">
          <div className="space-y-4">
             <h2 className="text-3xl md:text-5xl font-black text-white font-heading">
                ¿Su familiar necesita una <br /> intervención como estas?
             </h2>
             <p className="text-blue-100/60 font-medium text-lg max-w-2xl mx-auto">
                No espere a que el cuadro clínico empeore. Actuamos con la misma precisión y rigor en cada hogar.
             </p>
          </div>

          <div className="flex flex-col sm:flex-row items-center justify-center gap-6">
             <a href="/contacto/" className="group flex items-center gap-4 bg-[#155ec0] text-white px-10 py-5 rounded-2xl font-bold text-lg hover:bg-blue-700 transition-all shadow-2xl hover:shadow-blue-500/30">
                Iniciar Valoración Clínica
                <ArrowRight className="size-5 group-hover:translate-x-1 transition-transform" />
             </a>
             <a href="tel:+1234567890" className="flex items-center gap-3 text-white font-black text-sm uppercase tracking-widest border border-white/20 px-8 py-5 rounded-2xl hover:bg-white/5 transition-colors">
                <Phone className="size-5 text-blue-400" />
                Línea de Urgencia Líder
             </a>
          </div>
       </div>

       {/* Sutil Grid Background */}
       <div className="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 40px 40px;"></div>
    </section>
  </main>
</Layout>
