---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <section class="bg-primary text-white py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Impacto Medible</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 leading-tight">
          Resultados Medibles: La Evidencia de Nuestra Excelencia en Cuidado Domiciliario.
        </h1>
        <p class="text-white/80 text-lg max-w-3xl mx-auto mb-10">
          Nuestra <strong>filosofía de mejora continua</strong> se basa en la <strong>medición rigurosa</strong> de <strong>indicadores clave de rendimiento (KPIs)</strong> que validan nuestra eficacia clínica e inversión estratégica.
        </p>
        <a href="/resultados/casos-exito/" class="inline-block bg-accent text-white font-semibold py-3 px-8 rounded-full hover:opacity-90 transition">
          Ver Casos de Éxito
        </a>
      </div>
    </section>

    <!-- MÉTRICAS -->
    <section class="py-20 px-6 bg-white">
      <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-8 text-center">
        {[
          { kpi: "95%", label: "Satisfacción del familiar responsable" },
          { kpi: "40%", label: "Reducción de reingresos hospitalarios" },
          { kpi: "98%", label: "Mejora en autonomía funcional del paciente" },
        ].map(m => (
          <div class="bg-gray-50 rounded-2xl p-10 border border-gray-100">
            <div class="text-5xl font-bold text-accent font-heading mb-3">{m.kpi}</div>
            <p class="text-gray-700">{m.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- LINKS A SUB-PÁGINAS -->
    <section class="py-12 px-6 bg-secondary text-white">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
        <a href="/resultados/casos-exito/" class="border border-white/30 rounded-2xl p-6 hover:bg-white/10 transition">
          <h2 class="font-bold text-lg mb-1">Casos de Éxito y Testimonios</h2>
          <p class="text-white/70 text-sm">Historias reales de familias que recuperaron su tranquilidad.</p>
        </a>
        <a href="/resultados/estudios-impacto/" class="border border-white/30 rounded-2xl p-6 hover:bg-white/10 transition">
          <h2 class="font-bold text-lg mb-1">Estudios de Impacto</h2>
          <p class="text-white/70 text-sm">Evidencia científica validada sobre nuestros resultados clínicos.</p>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
