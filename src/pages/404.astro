---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-primary flex items-center justify-center px-6">
    <div class="text-center text-white max-w-xl">
      <div class="text-8xl font-bold font-heading text-accent/30 mb-4">404</div>
      <h1 class="text-3xl md:text-4xl font-bold font-heading mb-4">¡Ups! Página No Encontrada.</h1>
      <p class="text-white/70 text-lg mb-10">La página que busca no existe o fue movida. Explore nuestros servicios o contáctenos directamente.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-accent text-white font-semibold py-3 px-8 rounded-full hover:opacity-90 transition">
          Ir a la Home
        </a>
        <a href="/contacto/" class="border border-white text-white font-semibold py-3 px-8 rounded-full hover:bg-white/10 transition">
          Contactar Soporte
        </a>
      </div>
    </div>
  </main>
</Layout>
