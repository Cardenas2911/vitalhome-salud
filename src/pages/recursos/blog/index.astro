---
import Layout from "../../../layouts/Layout.astro";
import { 
  Calendar, 
  User, 
  ChevronRight, 
  Search, 
  ArrowRight,
  Bookmark,
  Clock,
  MessageCircle,
  TrendingUp,
  Award
} from "lucide-react";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";

const breadcrumbItems = [
  { label: "Recursos", href: "/recursos/" },
  { label: "Blog y Artículos", isCurrent: true }
];

const pageTitle = "Blog de Salud Domiciliaria | VitalHome Salud";
const pageDescription = "Artículos expertos sobre geriatría, cuidados avanzados y bienestar en el hogar. La guía definitiva para el familiar responsable.";

// Mock de artículos para la estructura visual
const posts = [
  {
    title: "5 Señales de Alerta: Cuándo el cuidado del familiar supera la capacidad del hogar",
    excerpt: "Identifique los indicadores clínicos y emocionales que sugieren la transición hacia una enfermería profesional domiciliaria.",
    author: "Dra. Claudia R.",
    date: "12 Abril, 2026",
    readTime: "8 min",
    category: "Geriatría",
    image: "/images/blog/signals-care.jpg",
    tags: ["Prevención", "Familia"]
  },
  {
    title: "Nutrición en Pacientes Postrados: Evitando la Sarcopenia",
    excerpt: "Protocolos dietéticos avanzados para mantener la masa muscular y fortalecer el sistema inmune en adultos mayores.",
    author: "Nutr. Andrés V.",
    date: "10 Abril, 2026",
    readTime: "6 min",
    category: "Nutrición Clínica",
    image: "/images/blog/nutrition-sarcopenia.jpg",
    tags: ["Salud", "Protocolo"]
  },
  {
    title: "Control del Dolor en el Hogar: Mitos y Realidades",
    excerpt: "Cómo la enfermería especializada gestiona escalas de dolor complejas sin necesidad de traslados hospitalarios.",
    author: "Enf. Jefe Patricia M.",
    date: "08 Abril, 2026",
    readTime: "10 min",
    category: "Cuidados Especiales",
    image: "/images/blog/pain-control.jpg",
    tags: ["Confort", "Paliativos"]
  }
];

const categories = ["Geriatría", "Nutrición Clínica", "Cuidados Especiales", "Bienestar Familiar", "Tecnología Médica"];
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="bg-[#f8f9fa] min-h-screen pt-32 md:pt-48 relative">
    
    {/* BREADCRUMBS OVER HERO */}
    <div class="absolute top-24 md:top-36 left-0 right-0 z-40">
        <div class="container mx-auto px-6">
            <Breadcrumbs client:load items={breadcrumbItems} />
        </div>
    </div>
    
    {/* HEADER DEL BLOG - CLINICAL GREY */}
    <section class="pt-4 md:pt-10 pb-16 lg:pb-24 border-b border-slate-200 bg-white">
        <div class="container mx-auto px-6">
            <div class="max-w-4xl space-y-6">
                <div class="flex items-center gap-2 text-[#155ec0] font-black text-[10px] uppercase tracking-[0.2em] animate-fade-in">
                    <Award class="size-4" />
                    <span>Contenido Auditado por Junta Médica</span>
                </div>
                <h1 class="text-5xl md:text-6xl font-black text-[#061a36] font-heading leading-tight italic">
                    El Pulso de la <br class="hidden md:block" /> Salud en el Hogar.
                </h1>
                <p class="text-slate-500 text-lg md:text-xl font-medium max-w-2xl leading-relaxed italic">
                    Artículos diseñados para dotar de conocimiento clínico al cuidador, transformando la incertidumbre en decisiones informadas.
                </p>
            </div>
        </div>
    </section>

    {/* NAVEGACIÓN DE CATEGORÍAS & BUSCADOR */}
    <div class="sticky top-20 z-40 bg-white/80 backdrop-blur-lg border-b border-slate-100 py-4 shadow-sm">
        <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
            <nav class="flex gap-6 overflow-x-auto pb-2 scrollbar-hide w-full md:w-auto">
                <button class="text-xs font-black text-[#155ec0] uppercase tracking-widest border-b-2 border-[#155ec0] pb-1">Todos</button>
                {categories.map(cat => (
                    <button class="text-xs font-black text-slate-400 hover:text-[#104892] uppercase tracking-widest transition-colors pb-1 whitespace-nowrap">{cat}</button>
                ))}
            </nav>
            <div class="relative w-full md:w-72">
                <Search class="absolute left-4 top-1/2 -translate-y-1/2 size-4 text-slate-400" />
                <input type="text" placeholder="Buscar artículo..." class="w-full bg-slate-50 border border-slate-100 rounded-full py-2.5 pl-11 pr-4 text-sm font-medium focus:ring-2 focus:ring-blue-100 outline-none transition-all" />
            </div>
        </div>
    </div>

    {/* GRID DE ARTÍCULOS */}
    <section class="py-20 container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {posts.map((post, idx) => (
                <article class="bg-white rounded-[40px] overflow-hidden border border-[#e2e8f0] hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 group flex flex-col">
                    {/* Imagen con Overlay Informativo */}
                    <div class="relative aspect-video bg-slate-100 overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-t from-[#061a36]/60 to-transparent opacity-60"></div>
                        <span class="absolute top-6 left-6 z-10 bg-[#155ec0] text-white text-[10px] font-black uppercase tracking-widest px-4 py-1.5 rounded-full">
                            {post.category}
                        </span>
                        
                        {/* Placeholder Icon while no real image */}
                        <div class="w-full h-full flex items-center justify-center">
                            <TrendingUp class="size-16 text-blue-50 opacity-20 group-hover:scale-110 transition-transform duration-700" />
                        </div>
                    </div>

                    <div class="p-8 md:p-10 flex flex-col flex-grow">
                        <div class="flex items-center gap-4 text-[10px] font-black text-slate-400 uppercase tracking-widest mb-6">
                            <span class="flex items-center gap-1.5"><Calendar class="size-3" /> {post.date}</span>
                            <span class="flex items-center gap-1.5"><Clock class="size-3" /> {post.readTime}</span>
                        </div>

                        <h3 class="text-2xl font-black text-[#061a36] font-heading leading-tight mb-4 group-hover:text-[#155ec0] transition-colors">
                            {post.title}
                        </h3>

                        <p class="text-slate-500 font-medium text-sm leading-relaxed mb-8 italic line-clamp-3">
                            {post.excerpt}
                        </p>

                        <div class="mt-auto pt-8 border-t border-slate-50 flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <div class="size-8 rounded-full bg-blue-50 flex items-center justify-center text-[#155ec0]">
                                    <User class="size-4" />
                                </div>
                                <span class="text-xs font-bold text-[#104892]">{post.author}</span>
                            </div>
                            <div class="size-10 rounded-full border border-slate-100 flex items-center justify-center text-slate-300 group-hover:bg-[#061a36] group-hover:text-white transition-all">
                                <ChevronRight class="size-5" />
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
        
        {/* PAGINACIÓN SIMULADA */}
        <div class="mt-20 flex justify-center">
            <button class="bg-white border border-[#e2e8f0] text-slate-400 px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:border-[#155ec0] hover:text-[#155ec0] transition-colors shadow-sm">
                Cargar más artículos experto
            </button>
        </div>
    </section>

    {/* NEWSLETTER - CAPTURA DE LEADS TOFU */}
    <section class="py-24 bg-[#061a36] relative overflow-hidden">
        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-4xl mx-auto text-center space-y-10">
                <div class="space-y-4">
                    <h2 class="text-3xl md:text-5xl font-black text-white font-heading">
                        Conocimiento Clínico <br/> en su Bandeja de Entrada.
                    </h2>
                    <p class="text-blue-100/60 font-medium text-lg italic">
                        Únase a más de 500 familiares que reciben protocolos de prevención y noticias de salud geriátrica cada semana.
                    </p>
                </div>

                <form class="flex flex-col gap-4 max-w-2xl mx-auto">
                    <div class="flex flex-col sm:flex-row gap-4">
                        <input 
                            type="email" 
                            name="email"
                            required
                            placeholder="Su correo electrónico profesional..." 
                            class="flex-grow bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white font-medium focus:ring-2 focus:ring-blue-400 outline-none transition-all"
                        />
                        <input 
                            type="text" 
                            name="address"
                            required
                            placeholder="Dirección de Residencia" 
                            class="flex-grow bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white font-medium focus:ring-2 focus:ring-blue-400 outline-none transition-all"
                        />
                    </div>
                    <button class="bg-[#155ec0] text-white px-10 py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-blue-600 transition-all shadow-xl shadow-blue-500/20 active:scale-95">
                        Suscribirse Gratis
                    </button>
                </form>
                <p class="text-[10px] text-white/30 font-black uppercase tracking-widest italic">
                    No enviamos spam. Solo ciencia y bienestar para su hogar.
                </p>
            </div>
        </div>
        
        {/* Decoración */}
        <div class="absolute inset-0 opacity-5 pointer-events-none" style="background-image: linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, .05) 25%, rgba(255, 255, 255, .05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .05) 75%, rgba(255, 255, 255, .05) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, .05) 25%, rgba(255, 255, 255, .05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, .05) 75%, rgba(255, 255, 255, .05) 76%, transparent 77%, transparent); background-size: 50px 50px;"></div>
    </section>
  </main>
</Layout>
