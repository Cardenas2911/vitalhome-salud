---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <section class="bg-secondary text-white py-24 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-3">Herramientas de Cuidado</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 leading-tight">
          Guías Prácticas: Recursos Descargables para un Cuidado Domiciliario Efectivo.
        </h1>
        <p class="text-white/80 text-lg max-w-3xl mx-auto">
          Acceda a <strong>guías y descargables exclusivos</strong> diseñados por expertos en <strong>salud domiciliaria</strong>: <strong>listas de verificación</strong>, <strong>plantillas de planificación de cuidados</strong>, <strong>ejercicios de rehabilitación</strong> y <strong>consejos nutricionales</strong>.
        </p>
      </div>
    </section>

    <section class="py-20 px-6 bg-white">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
        {[
          { titulo: "Kit del Familiar Responsable", tipo: "PDF Descargable", desc: "Guía completa con herramientas para gestionar el cuidado diario sin abrumarse." },
          { titulo: "Ejercicios de Rehabilitación en Casa", tipo: "PDF Ilustrado", desc: "Rutina de ejercicios progresivos validada por fisioterapeutas para adultos mayores." },
          { titulo: "Planilla de Monitoreo Diario", tipo: "Plantilla Excel/PDF", desc: "Registro estructurado de signos vitales, medicación y evolución del paciente." },
          { titulo: "Guía de Nutrición Geriátrica", tipo: "PDF Descargable", desc: "Menús semanales y recomendaciones nutricionales para el adulto mayor en casa." },
        ].map(g => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <span class="text-xs font-bold uppercase tracking-widest text-accent">{g.tipo}</span>
            <h2 class="text-xl font-bold text-primary font-heading mt-2 mb-3">{g.titulo}</h2>
            <p class="text-gray-600 text-sm mb-4">{g.desc}</p>
            <a href="/contacto/" class="text-accent font-semibold text-sm hover:underline">Descargar →</a>
          </div>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
