---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  Briefcase, 
  Clock, 
  HeartHandshake, 
  BadgeCheck, 
  ChevronRight,
  Stethoscope,
  Send
} from "lucide-react";

const title = "Trabaje Con Nosotros | VitalHome Salud";
const breadcrumbItems = [
  { label: "Institucional", href: "/nosotros/" },
  { label: "Trabaje Con Nosotros", isCurrent: true }
];
---

<Layout title={title}>
  <Header />

  <main class="w-full bg-[#f8fafc] pt-28 md:pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-6 md:pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- SECCIÓN 1: Hero -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative mb-24">
        <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <div class="p-8 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center relative z-10">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Carreras VitalHome Salud
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading text-glow">
                Únase al Equipo que <span class="text-blue-400">Transforma el Cuidado en Casa.</span>
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                Buscamos profesionales con vocación inquebrantable, alto nivel ético y excelencia humana. Al unirse a VitalHome Salud, no solo obtiene estabilidad laboral, sino la oportunidad de impactar vidas elevando el estándar del bienestar y el cuidado clínico domiciliario.
              </p>
            </div>
            
            <a href="#vacantes" class="w-fit bg-[#155ec0] hover:bg-white text-white hover:text-[#061a36] flex items-center justify-center gap-3 font-black text-[12px] uppercase tracking-[0.2em] px-8 py-5 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1">
              Ver Ofertas Actuales
              <ChevronRight className="size-4" />
            </a>
          </div>

          <div class="bg-white/5 lg:bg-transparent p-6 md:p-12 lg:p-20 flex flex-col justify-center items-center">
            <div class="bg-white rounded-[40px] p-2 shadow-2xl relative z-10 border border-slate-100 overflow-hidden group">
               <div class="relative overflow-hidden rounded-[38px]">
                  <img 
                    src="/images/medico_atencion_real.png" 
                    alt="Profesional de salud de VitalHome Salud en atención domiciliaria" 
                    class="w-full h-full min-h-[400px] object-cover grayscale-[0.1] transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-[#061a36]/80 to-transparent"></div>
                  <div class="absolute bottom-6 left-6 right-6 md:bottom-10 md:left-10 md:right-10">
                     <p class="text-white font-black text-lg md:text-xl leading-snug">"Trabajar aquí significa ser parte de una familia que valora mi profesión humana."</p>
                     <p class="text-blue-300 text-[9px] md:text-[10px] font-bold uppercase tracking-widest mt-2">Enfermera Especialista VitalHome Salud</p>
                  </div>
               </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SECCIÓN 2: Beneficios -->
      <section class="max-w-[1600px] mx-auto pt-16 pb-32">
        <div class="text-center mb-24 space-y-4">
          <span class="text-[10px] font-black text-[#104892] uppercase tracking-[0.4em]">Por qué elegirnos</span>
          <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Condiciones Superiores <span class="text-[#155ec0]">para Talentos Superiores.</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-6 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Briefcase className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Estabilidad y Claridad</h4>
              <p class="text-slate-500 font-medium text-sm leading-relaxed">
                Contratos claros, remuneración competitiva y pagos puntuales. Valoramos su esfuerzo y profesionalismo desde el primer día.
              </p>
            </div>
          </div>

          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-6 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Clock className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Turnos Flexibles</h4>
              <p class="text-slate-500 font-medium text-sm leading-relaxed">
                Diseñamos esquemas de turnos que se adaptan a su disponibilidad temporal. Queremos que nuestro personal mantenga un balance saludable entre vida y trabajo.
              </p>
            </div>
          </div>

          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-6 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <HeartHandshake className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Respaldo Institucional</h4>
              <p class="text-slate-500 font-medium text-sm leading-relaxed">
                Usted nunca está solo en un servicio. Cuenta con supervisión y apoyo incondicional de nuestros médicos y enfermeras jefes de turno.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- SECCIÓN 3: Formulario Postulación -->
      <section id="vacantes" class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-32 bg-[#eceef0] rounded-[60px] relative overflow-hidden mb-20">
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-200/30 blur-[100px] rounded-full"></div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center relative z-10">
          
          <div class="space-y-8">
            <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading leading-tight">Postúlese Ahora a <span class="text-[#155ec0]">Nuestras Vacantes.</span></h2>
            <p class="text-lg text-slate-600 font-medium leading-relaxed">
              Siempre estamos en búsqueda del talento médico y clínico que marca la diferencia. Llene el formato a detalle y nuestro equipo de selección se pondrá en contacto pronto.
            </p>
            
            <div class="flex flex-col gap-4 mt-8">
               <div class="flex items-center gap-4 text-[#061a36]">
                  <BadgeCheck className="text-[#155ec0] size-6" />
                  <span class="font-bold text-sm">Validamos tarjeta profesional Vigente</span>
               </div>
               <div class="flex items-center gap-4 text-[#061a36]">
                  <BadgeCheck className="text-[#155ec0] size-6" />
                  <span class="font-bold text-sm">Realizamos verificación de antecedentes disciplinarios</span>
               </div>
               <div class="flex items-center gap-4 text-[#061a36]">
                  <BadgeCheck className="text-[#155ec0] size-6" />
                  <span class="font-bold text-sm">Valoramos experiencia en instituciones hospitalarias previas</span>
               </div>
            </div>
          </div>

          <!-- Formulario -->
          <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl border border-slate-100 w-full relative">
            
            <h4 class="text-2xl font-black text-[#011633] font-heading mb-8">Aplicación Profesional</h4>
            <form method="POST" class="space-y-6">
              
              <div class="space-y-2">
                 <input type="text" name="nombre" placeholder="Nombres y Apellidos Completos" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 <input type="email" name="email" placeholder="Correo Electrónico" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
                 <input 
                    type="tel" 
                    name="telefono" 
                    placeholder="Número Celular" 
                    required 
                    inputmode="numeric"
                    oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                    class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" 
                 />
              </div>

              <div class="space-y-2">
                <select name="servicio" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none appearance-none cursor-pointer">
                  <option value="" disabled selected>Profesión / Especialidad (Obligatorio)</option>
                  <option value="enfermeria_profesional">Enfermería Profesional (Jefe)</option>
                  <option value="auxiliar_enfermeria">Auxiliar de Enfermería</option>
                  <option value="medicina_general">Medicina General</option>
                  <option value="fisioterapia">Fisioterapeuta / Rehabilitador(a)</option>
                  <option value="terapia_ocupacional">Terapia Ocupacional</option>
                  <option value="terapia_respiratoria">Terapia Respiratoria</option>
                  <option value="psicologia">Psicología Clínica</option>
                  <option value="otra">Otra Especialidad Clínica</option>
                </select>
              </div>

              <div class="space-y-2">
                <input type="text" name="ciudad" placeholder="Ciudad de Residencia" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              </div>
              
              <div class="space-y-2">
                <textarea name="mensaje" rows="3" placeholder="Breve perfil profesional y motivo de interés en VitalHome Salud" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none resize-none"></textarea>
              </div>

              <button type="submit" class="w-full h-[60px] bg-[#155ec0] hover:bg-[#061a36] text-white flex items-center justify-center gap-3 font-black text-[12px] uppercase tracking-[0.2em] rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1">
                Enviar Aplicación
                <Send className="size-4" />
              </button>
            </form>
          </div>
        </div>
      </section>

    </div>
  </main>

  <Footer />

</Layout>

<style>
  html { scroll-behavior: smooth; }
  .text-glow { text-shadow: 0 0 40px rgba(96, 165, 250, 0.4); }
</style>
