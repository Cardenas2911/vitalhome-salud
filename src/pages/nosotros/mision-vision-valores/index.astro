---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { Breadcrumbs } from "../../../components/ui/breadcrumbs";
import { 
  Target, 
  Eye, 
  ShieldCheck, 
  Heart, 
  Scale, 
  Activity, 
  ChevronRight,
  Shield,
  Star,
  Users
} from "lucide-react";

// Marcado JSON-LD Avanzado (@graph)
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud"
    },
    {
      "@type": "AboutPage",
      "@id": "https://vitalhomesalud.com/nosotros/mision-vision-valores/#webpage",
      "url": "https://vitalhomesalud.com/nosotros/mision-vision-valores/",
      "name": "Misión, Visión y Valores de VitalHome Salud",
      "description": "Nuestra misión es proporcionar servicios de asistencia domiciliaria que promuevan la calidad de vida de usuarios geriátricos y post-operatorios, rigiéndonos por principios éticos y profesionales sólidos.",
      "isPartOf": {
        "@id": "https://vitalhomesalud.com/#website"
      },
      "about": {
        "@id": "https://vitalhomesalud.com/#organization"
      }
    }
  ]
};

const title = "Misión, Visión y Valores | Institución Domiciliaria | VitalHome Salud";
const breadcrumbItems = [
  { label: "Institucional", href: "/nosotros/" },
  { label: "Misión, Visión y Valores", isCurrent: true }
];
---

<Layout title={title}>
  <Header />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#f8fafc] pt-28 md:pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan: Inicio > Institucional > Misión, Visión y Valores -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-6 md:pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- SECCIÓN 1: Hero de Propósito (Split-Screen) -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative mb-24">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <!-- Columna Izquierda: Texto -->
          <div class="p-10 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Nuestro ADN Institucional
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading text-glow">
                Nuestra Esencia: <span class="text-blue-400">Cuidado con Propósito y Valores.</span>
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                Más que una institución de salud, somos el respaldo que su familia necesita en los momentos más vulnerables. En VitalHome Salud, cada acción clínica que realizamos está guiada por un profundo compromiso ético y humano, diseñado para devolverle la dignidad a su ser querido y la paz mental a usted.
              </p>
            </div>
          </div>

          <!-- Columna Derecha: Isla Clínica -->
          <div class="bg-white/5 lg:bg-transparent p-6 md:p-12 lg:p-20 flex flex-col justify-center">
            <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl relative z-10 border border-slate-100">
              <div class="text-center mb-10">
                <h3 class="text-2xl font-black text-[#011633] font-heading mb-2">Compromiso Institucional</h3>
                <p class="text-slate-500 text-sm font-medium italic">Ética, transparencia y excelencia en cada hogar.</p>
              </div>

              <div class="space-y-5 mb-10">
                <div class="flex items-center gap-4 text-slate-600 font-bold text-xs uppercase tracking-widest bg-slate-50 p-4 rounded-2xl">
                   <Shield className="size-4 text-[#155ec0]" /> Protección Integral
                </div>
                <div class="flex items-center gap-4 text-slate-600 font-bold text-xs uppercase tracking-widest bg-slate-50 p-4 rounded-2xl">
                   <Star className="size-4 text-[#155ec0]" /> Máxima Especialidad
                </div>
                <div class="flex items-center gap-4 text-slate-600 font-bold text-xs uppercase tracking-widest bg-slate-50 p-4 rounded-2xl">
                   <Users className="size-4 text-[#155ec0]" /> Enfoque Familiar
                </div>
              </div>

              <a 
                href="/contacto/" 
                class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white flex items-center justify-center gap-3 font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1"
              >
                Conocer Nuestro Compromiso
                <ChevronRight className="size-4" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- SECCIÓN 2: La Misión (Nuestro Deber Diario) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-32 bg-[#f8f9fa] rounded-[60px] mb-24 border border-slate-100 shadow-sm relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-blue-100/20 blur-[100px] rounded-full"></div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
          <div class="lg:col-span-4 flex justify-center lg:justify-start">
             <div class="size-32 md:size-48 bg-[#061a36] rounded-[40px] flex items-center justify-center shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500">
                <Target className="size-16 md:size-24 text-blue-400" />
             </div>
          </div>
          <div class="lg:col-span-8 space-y-8">
            <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Misión: <span class="text-[#155ec0]">Promover la Calidad de Vida en su Propio Hogar.</span></h2>
            <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
              Nuestra misión es proporcionar servicios de asistencia domiciliaria de élite que promuevan la calidad de vida de usuarios geriátricos, post-operatorios o con limitaciones físicas y mentales. Nos regimos por principios éticos absolutos y contamos con profesionales caracterizados por su solidez de conocimientos. Nuestro objetivo es identificar y resolver las necesidades reales y potenciales tanto del paciente como de su familia, garantizando un entorno seguro y de recuperación óptima.
            </p>
          </div>
        </div>
      </section>

      <!-- SECCIÓN 3: La Visión (El Estándar del Futuro) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-32 bg-white rounded-[60px] mb-24 border border-slate-100 shadow-sm relative overflow-hidden">
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-50 blur-[100px] rounded-full"></div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center relative z-10">
          <div class="lg:col-span-8 order-2 lg:order-1 space-y-8">
            <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading text-right lg:text-left">Visión: <span class="text-[#155ec0]">Ser el Referente Nacional en Continuidad de Cuidados.</span></h2>
            <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed text-right lg:text-left">
              Nos proyectamos como la institución domiciliaria líder y reconocida por los sectores público y privado en atención de enfermería y cuidado integral. Nuestra visión es asegurar la continuidad impecable de los cuidados tras una hospitalización, siendo el recurso de apoyo fundamental para que el paciente recupere su nivel de funcionamiento previo, bajo los más altos estándares de calidad a nivel nacional.
            </p>
          </div>
          <div class="lg:col-span-4 order-1 lg:order-2 flex justify-center lg:justify-end">
             <div class="size-32 md:size-48 bg-[#155ec0] rounded-[40px] flex items-center justify-center shadow-2xl -rotate-3 hover:rotate-0 transition-transform duration-500">
                <Eye className="size-16 md:size-24 text-white" />
             </div>
          </div>
        </div>
      </section>

      <!-- SECCIÓN 4: Nuestros Valores (Bento Grid de 4 Pilares) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-32 bg-[#eceef0] rounded-[60px]">
        <div class="text-center mb-24 space-y-4">
          <span class="text-[10px] font-black text-[#104892] uppercase tracking-[0.4em]">Manifiesto Clínico</span>
          <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Los Pilares de Nuestra <span class="text-[#155ec0]">Excelencia Clínica.</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Valor 1: Excelencia -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <ShieldCheck className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Excelencia Clínica</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Profesionales con amplia experiencia asistencial y en constante capacitación (diplomados, foros, seminarios) para ofrecer un servicio de salud superior y actualizado.
              </p>
            </div>
          </div>

          <!-- Valor 2: Ética -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Scale className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Ética y Honestidad</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Actuamos con total transparencia y responsabilidad legal en el manejo de la información médica y el trato digno al paciente geriátrico o dependiente.
              </p>
            </div>
          </div>

          <!-- Valor 3: Empatía -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Heart className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Calidez Humana (Empatía)</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Entendemos el estrés emocional del núcleo familiar. Nuestro equipo se compromete a brindar un apoyo humano genuino y compasivo en cada visita domiciliaria.
              </p>
            </div>
          </div>

          <!-- Valor 4: Seguridad -->
          <div class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 h-full">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Shield className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Seguridad y Confiabilidad</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Cumplimiento irrestricto de los lineamientos exigidos por los entes reguladores de salud, garantizando un entorno hospitalario libre de riesgos en su propio hogar.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- SECCIÓN 5: Footer de Conversión (Z-Pattern) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <!-- Mensaje de Cierre (Left) -->
          <div class="space-y-12">
            <h3 class="text-3xl md:text-5xl font-black text-[#104892] font-heading leading-tight italic">Si comparte nuestros valores, permítanos cuidar de los suyos.</h3>
            <p class="text-lg text-slate-500 font-medium italic">En VitalHome Salud no enviamos personal, enviamos tranquilidad respaldada por una filosofía de vida.</p>
          </div>

          <!-- Formulario Minimalista (Right) -->
          <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl border border-slate-100 w-full max-w-xl lg:ml-auto">
            <h4 class="text-2xl font-black text-[#011633] font-heading mb-8 uppercase tracking-tighter">Valoración Respaldada</h4>
            <form class="space-y-6">
              <input type="text" name="name" required placeholder="Su Nombre Completo" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
              <input type="tel" name="phone" required placeholder="WhatsApp de Contacto" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
              <input type="text" name="address" required placeholder="Dirección de Residencia" class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all" />
              <select name="pathology" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none transition-all appearance-none cursor-pointer">
                <option value="" disabled selected>Tipo de Patología</option>
                <option value="diabetes">Diabetes / Hipertensión</option>
                <option value="alzheimer">Alzheimer / Demencia</option>
                <option value="post-operatorio">Recuperación Post-Operatoria</option>
                <option value="respiratorio">Enfermedad Respiratoria</option>
                <option value="paliativo">Cuidado Paliativo / Crónico</option>
                <option value="movilidad">Limitación de Movilidad</option>
                <option value="otros">Otras / Varias</option>
              </select>
              <button type="submit" class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1">
                Solicitar Valoración Respaldada
              </button>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />

  <!-- CTA Sticky Flotante -->

</Layout>

<style>
  html { scroll-behavior: smooth; }
  .text-glow { text-shadow: 0 0 40px rgba(96, 165, 250, 0.4); }
</style>
