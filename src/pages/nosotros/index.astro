---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Breadcrumbs } from "../../components/ui/breadcrumbs";
import { 
  ShieldCheck, 
  Users, 
  Heart, 
  History, 
  Scale, 
  ArrowRight,
  ChevronRight,
  Plus,
  Microscope,
  Stethoscope,
  Activity
} from "lucide-react";

// Metadatos y Marcado JSON-LD Avanzado (@graph)
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalOrganization",
      "@id": "https://vitalhomesalud.com/#organization",
      "name": "VitalHome Salud",
      "description": "Agencia de servicios de salud a nivel domiciliario y hospitalario, con un equipo de profesionales altamente calificados y en constante capacitación.",
      "url": "https://vitalhomesalud.com",
      "logo": "https://vitalhomesalud.com/logo.png"
    },
    {
      "@type": "AboutPage",
      "@id": "https://vitalhomesalud.com/nosotros/#webpage",
      "url": "https://vitalhomesalud.com/nosotros/",
      "name": "Quiénes Somos - VitalHome Salud",
      "isPartOf": {
        "@id": "https://vitalhomesalud.com/#website"
      },
      "about": {
        "@id": "https://vitalhomesalud.com/#organization"
      },
      "hasPart": [
        {
          "@type": "WebPage",
          "url": "https://vitalhomesalud.com/nosotros/metodologia-vitalhome/",
          "name": "Metodología VitalHome®"
        },
        {
          "@type": "WebPage",
          "url": "https://vitalhomesalud.com/nosotros/equipo-profesional/",
          "name": "Nuestro Equipo Profesional"
        },
        {
          "@type": "WebPage",
          "url": "https://vitalhomesalud.com/nosotros/mision-vision-valores/",
          "name": "Misión, Visión y Valores"
        },
        {
          "@type": "WebPage",
          "url": "https://vitalhomesalud.com/nosotros/historia/",
          "name": "Nuestra Historia"
        },
        {
          "@type": "WebPage",
          "url": "https://vitalhomesalud.com/nosotros/gobierno-corporativo/",
          "name": "Gobierno Corporativo"
        }
      ]
    }
  ]
};

const title = "Quiénes Somos | Institución de Cuidado Domiciliario | VitalHome Salud";
const breadcrumbItems = [
  { label: "Institucional", href: "/nosotros/" },
  { label: "Quiénes Somos", isCurrent: true }
];
---

<Layout title={title}>
  <Header />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />

  <main class="w-full bg-[#f8fafc] pt-28 md:pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan (Breadcrumbs) Inicio > Institucional > Quiénes Somos -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-6 md:pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- SECCIÓN 1: Hero de Autoridad (Split-Screen) -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative mb-24">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <!-- Columna Izquierda: Texto -->
          <div class="p-10 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Institución de Salud
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading text-glow">
                Cuidado Domiciliario de Élite: <span class="text-blue-400">Conozca a VitalHome Salud.</span>
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                Somos una institución de servicios de salud a nivel domiciliario y hospitalario, nacida de la necesidad de brindar a cada paciente una recuperación óptima desde la comodidad de su hogar. Operamos bajo estrictos lineamientos normativos, combinando precisión clínica con un profundo respeto por su núcleo familiar.
              </p>
            </div>
          </div>

          <!-- Columna Derecha: Isla Clínica -->
          <div class="bg-white/5 lg:bg-transparent p-6 md:p-12 lg:p-20 flex flex-col justify-center">
            <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl relative z-10 border border-slate-100">
              <div class="space-y-8 mb-12">
                <div class="flex items-start gap-4 p-4 rounded-3xl bg-blue-50/50">
                  <ShieldCheck className="size-6 text-[#155ec0] shrink-0 mt-1" />
                  <div>
                    <h4 class="font-black text-[#011633] text-sm uppercase tracking-wider">Seguridad Clínica</h4>
                    <p class="text-slate-500 text-xs font-medium">Protocolos auditados las 24 horas por enfermeras jefe.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-4 rounded-3xl bg-blue-50/50">
                  <Activity className="size-6 text-[#155ec0] shrink-0 mt-1" />
                  <div>
                    <h4 class="font-black text-[#011633] text-sm uppercase tracking-wider">Confiabilidad</h4>
                    <p class="text-slate-500 text-xs font-medium">Personal rigorosamente seleccionado y certificado.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-4 rounded-3xl bg-blue-50/50">
                  <Heart className="size-6 text-[#155ec0] shrink-0 mt-1" />
                  <div>
                    <h4 class="font-black text-[#011633] text-sm uppercase tracking-wider">Recuperación Integral</h4>
                    <p class="text-slate-500 text-xs font-medium">Enfoque multidisciplinario para el retorno a la autonomía.</p>
                  </div>
                </div>
              </div>

              <a 
                href="/contacto/" 
                class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white flex items-center justify-center gap-3 font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1 cursor-pointer"
              >
                Solicitar Valoración Clínica
                <ChevronRight className="size-4" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- SECCIÓN 2: Hub de Navegación Institucional (Bento Grid) -->
      <section class="max-w-[1600px] mx-auto pt-16 pb-32">
        <div class="text-center mb-24 space-y-4">
          <span class="text-[10px] font-black text-[#104892] uppercase tracking-[0.4em]">Silo de Confianza</span>
          <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading">Conozca Nuestro <span class="text-[#155ec0]">Ecosistema de Excelencia.</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          
          <!-- Metodología -->
          <a href="/metodologia/" class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 hover:-translate-y-1">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Microscope className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Metodología VitalHome®</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                La ingeniería detrás de nuestro cuidado integral. Un sistema probado de evaluación, intervención y monitoreo clínico.
              </p>
            </div>
            <div class="pt-4 mt-auto">
               <span class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest flex items-center gap-2">Explorar Sistema <ChevronRight className="size-3" /></span>
            </div>
          </a>

          <!-- Equipo -->
          <a href="/nosotros/equipo/" class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 hover:-translate-y-1">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Stethoscope className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Equipo Profesional</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Conozca al equipo multidisciplinario (enfermeras, médicos, terapeutas) respaldado por un riguroso proceso de selección.
              </p>
            </div>
            <div class="pt-4 mt-auto">
               <span class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest flex items-center gap-2">Ver Perfiles <ChevronRight className="size-3" /></span>
            </div>
          </a>

          <!-- Misión, Visión y Valores -->
          <a href="/nosotros/mision-vision-valores/" class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 hover:-translate-y-1 md:col-span-2 lg:col-span-1">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Heart className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Nuestra Ética y Valores</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Nuestro compromiso ético y humano para devolverle a su familiar su nivel de funcionamiento previo y dignidad.
              </p>
            </div>
            <div class="pt-4 mt-auto">
               <span class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest flex items-center gap-2">Conocer Compromiso <ChevronRight className="size-3" /></span>
            </div>
          </a>

          <!-- Historia -->
          <a href="/nosotros/historia/" class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 hover:-translate-y-1 lg:col-span-2">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <History className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Nuestra Historia</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                La trayectoria de vocación y servicio que nos consolida como líderes en el sector de la salud domiciliaria en Colombia.
              </p>
            </div>
            <div class="pt-4 mt-auto">
               <span class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest flex items-center gap-2">Ver Trayectoria <ChevronRight className="size-3" /></span>
            </div>
          </a>

          <!-- Gobierno Corporativo -->
          <a href="/nosotros/gobierno-corporativo/" class="bg-white rounded-[40px] p-10 border border-[#e2e8f0] group hover:border-[#155ec0] hover:shadow-2xl transition-all duration-500 flex flex-col gap-8 hover:-translate-y-1">
            <div class="size-16 rounded-2xl bg-blue-50 flex items-center justify-center shrink-0 group-hover:bg-[#155ec0] transition-colors text-[#155ec0] group-hover:text-white">
              <Scale className="size-8" />
            </div>
            <div>
              <h4 class="text-xl font-black text-[#011633] mb-4 font-heading group-hover:text-[#155ec0]">Gobierno Corporativo</h4>
              <p class="text-slate-500 font-medium text-base leading-relaxed">
                Transparencia, cumplimiento de lineamientos de salud y políticas éticas que garantizan su tranquilidad absoluta.
              </p>
            </div>
            <div class="pt-4 mt-auto">
               <span class="text-[#155ec0] font-black text-[10px] uppercase tracking-widest flex items-center gap-2">Transparencia <ChevronRight className="size-3" /></span>
            </div>
          </a>

        </div>
      </section>

      <!-- SECCIÓN 3: Destructor de Objeciones (Seguridad Total) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40 bg-[#eceef0] rounded-[80px]">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8">
            <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading leading-tight italic">¿Por qué confiar en VitalHome Salud?</h2>
            <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
              No dejamos nada al azar. Cada profesional de nuestro equipo supera un riguroso proceso de selección de titulaciones y antecedentes. Además, garantizamos un monitoreo clínico las 24 horas: nuestras enfermeras jefes auditan el inicio, desarrollo y finalización de cada turno mediante notas de enfermería estructuradas, asegurando el control absoluto del bienestar de su ser querido.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-4">
             <div class="bg-white p-8 rounded-[40px] border border-slate-200 space-y-4">
                <span class="text-4xl font-black text-[#155ec0]">100%</span>
                <p class="text-[#011633] font-black text-[10px] uppercase tracking-widest">Titulados y Certificados</p>
             </div>
             <div class="bg-[#061a36] p-8 rounded-[40px] space-y-4">
                <span class="text-4xl font-black text-blue-400">24/7</span>
                <p class="text-white/50 font-black text-[10px] uppercase tracking-widest">Supervisión Clínica</p>
             </div>
             <div class="bg-[#155ec0] p-8 rounded-[40px] col-span-2 space-y-4">
                <span class="text-2xl font-black text-white">Notas Estructuradas</span>
                <p class="text-white/70 font-black text-[10px] uppercase tracking-widest leading-relaxed">Auditoría en tiempo real de cada turno por enfermeras jefe.</p>
             </div>
          </div>
        </div>
      </section>

      <!-- SECCIÓN 4: Footer de Conversión (Patrón Z) -->
      <section class="max-w-[1600px] mx-auto px-4 md:px-8 py-24 lg:py-40">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <!-- Sellos de Autoridad (Left) -->
          <div class="space-y-12">
            <h3 class="text-2xl md:text-4xl font-black text-[#104892] font-heading leading-tight italic">Institución Respaldada por Estándares Éticos y Legales.</h3>
            <div class="flex flex-wrap gap-8 items-center opacity-60">
               <div class="h-16 w-32 bg-slate-200 rounded-2xl flex items-center justify-center text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center px-4">Entidad Salud Regulada</div>
               <div class="h-16 w-32 bg-slate-200 rounded-2xl flex items-center justify-center text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center px-4">Cumplimiento Normativo</div>
               <div class="h-16 w-32 bg-slate-200 rounded-2xl flex items-center justify-center text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center px-4">Calidad Auditada</div>
            </div>
          </div>

          <!-- Formulario Minimalista (Right) -->
          <div class="bg-white rounded-[40px] p-8 md:p-12 shadow-2xl border border-slate-100 w-full max-w-xl lg:ml-auto">
            <h4 class="text-2xl font-black text-[#011633] font-heading mb-8">Hable con un Especialista</h4>
            <form class="space-y-6">
              <input type="text" name="name" placeholder="Su Nombre" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              <input type="tel" name="phone" placeholder="WhatsApp / Teléfono" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              <input type="text" name="address" placeholder="Dirección de Residencia" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none" />
              <select name="pathology" required class="w-full bg-[#f8fafc] border border-[#e2e8f0] rounded-2xl px-6 py-4 text-[#061a36] font-semibold focus:ring-2 focus:ring-[#155ec0] outline-none appearance-none cursor-pointer">
                <option value="" disabled selected>Tipo de Patología</option>
                <option value="diabetes">Diabetes / Hipertensión</option>
                <option value="alzheimer">Alzheimer / Demencia</option>
                <option value="post-operatorio">Recuperación Post-Operatoria</option>
                <option value="respiratorio">Enfermedad Respiratoria</option>
                <option value="paliativo">Cuidado Paliativo / Crónico</option>
                <option value="movilidad">Limitación de Movilidad</option>
                <option value="otros">Otras / Varias</option>
              </select>
              <button type="submit" class="w-full bg-[#155ec0] hover:bg-[#061a36] text-white font-black text-[12px] uppercase tracking-[0.2em] py-6 rounded-2xl shadow-[0_20px_40px_rgba(21,94,192,0.4)] transition-all duration-500 hover:-translate-y-1">
                Contactar a un Especialista
              </button>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />

  <!-- CTA Sticky Flotante -->

</Layout>

<style>
  html { scroll-behavior: smooth; }
  .text-glow { text-shadow: 0 0 40px rgba(96, 165, 250, 0.4); }
</style>
