---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Breadcrumbs } from "../../components/ui/breadcrumbs";
import { MultiStepContactForm } from "../../components/forms/MultiStepContactForm";
import { 
  ShieldCheck, 
  Clock, 
  CheckCircle2, 
  MapPin, 
  Map as MapIcon,
  Phone, 
  Mail,
  ArrowRight,
  Stethoscope,
  Heart,
  MessageSquare,
  ChevronRight
} from "lucide-react";

// Basado en el Documento Maestro de Copywriting
const title = "Contacto y Valoración Gratuita | VitalHome Salud";
const description = "Contáctenos para solicitar una valoración gratuita o resolver sus dudas sobre nuestras especialidades médicas domiciliarias. Atención inmediata.";

const breadcrumbItems = [
  { label: "Contacto", isCurrent: true }
];
---

<Layout title={title}>
  <Header />

  <main class="w-full bg-[#f8fafc] pt-40 pb-24 overflow-hidden relative">
    
    <!-- Miga de Pan (Breadcrumbs) Estándar -->
    <div class="max-w-[1600px] mx-auto px-4 md:px-8 pb-12 relative z-20">
      <Breadcrumbs client:load items={breadcrumbItems} />
    </div>

    <!-- Background Elements (Mancha Azul sutil como en Servicios) -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/40 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-40 left-0 w-[500px] h-[500px] bg-blue-50/50 blur-[100px] rounded-full pointer-events-none"></div>

    <div class="max-w-[1600px] mx-auto px-4 md:px-8 relative z-10">
      
      <!-- Contenedor Hero con Recuadro Azul (Efecto de Aislamiento y Jerarquía) -->
      <div class="bg-[#061a36] rounded-[60px] overflow-hidden shadow-[0_50px_100px_rgba(0,0,0,0.2)] border border-white/5 relative">
        <!-- Mancha de luz interna para el recuadro -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#155ec0]/10 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 lg:gap-16 items-stretch">
          
          <!-- Columna Izquierda: Alivio Clínico -->
          <div class="p-10 md:p-16 lg:p-20 space-y-10 flex flex-col justify-center">
            <div class="space-y-6">
              <span class="text-[10px] font-black text-blue-400 uppercase tracking-[0.4em] bg-blue-400/10 px-4 py-2 rounded-full border border-blue-400/20 w-fit">
                Atención Prioritaria
              </span>
              <h1 class="text-4xl md:text-6xl font-black text-white leading-tight font-heading">
                Hablemos: Su camino hacia la <span class="text-blue-400">tranquilidad</span> comienza aquí.
              </h1>
              <p class="text-lg md:text-xl text-white/70 font-medium leading-relaxed">
                No tome decisiones médicas bajo estrés. Solicite hoy mismo una valoración gratuita. Nuestra enfermera jefe evaluará las necesidades de su familiar y le propondrá un plan de cuidado personalizado, sin ningún compromiso.
              </p>
            </div>

            <!-- Trust Signals -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <Clock className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Respuesta Rápida</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <Stethoscope className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Valoración en Casa</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <ShieldCheck className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Confidencialidad</span>
              </div>
              <div class="flex items-center gap-4 group">
                <div class="size-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-blue-400/20 transition-colors">
                  <CheckCircle2 className="size-6 text-blue-400" />
                </div>
                <span class="text-white font-bold text-sm">Rigor Clínico</span>
              </div>
            </div>
          </div>

          <!-- Columna Derecha: Formulario Paso a Paso -->
          <div class="p-6 md:p-12 lg:p-20 flex flex-col justify-center relative z-20">
            <MultiStepContactForm client:load />
          </div>
        </div>
      </div>
    </div>

    <!-- Sección 2: Canales de Atención Inmediata -->
    <section class="max-w-[1600px] mx-auto px-4 md:px-8 pt-32 pb-16">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-black text-[#011633] font-heading mb-4">Canales de Atención <span class="text-[#155ec0]">Directa</span></h2>
        <p class="text-slate-500 font-medium text-lg italic">Elegancia y rapidez en cada interacción clínica.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- WhatsApp -->
        <a href="https://wa.me/573138050356" target="_blank" class="group bg-white border border-[#e2e8f0] p-10 rounded-[40px] hover:shadow-2xl transition-all duration-500 text-center">
          <div class="size-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-[#155ec0] transition-colors">
            <MessageSquare className="size-8 text-[#155ec0] group-hover:text-white" />
          </div>
          <h4 class="text-xl font-black text-[#061a36] mb-2">WhatsApp Clínico</h4>
          <p class="text-slate-500 font-bold">Respuesta inmediata</p>
        </a>

        <!-- Phone -->
        <a href="tel:+573138050356" class="group bg-white border border-[#e2e8f0] p-10 rounded-[40px] hover:shadow-2xl transition-all duration-500 text-center">
          <div class="size-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-[#155ec0] transition-colors">
            <Phone className="size-8 text-[#155ec0] group-hover:text-white" />
          </div>
          <h4 class="text-xl font-black text-[#061a36] mb-2">Central 24/7</h4>
          <p class="text-slate-500 font-bold">Llamada prioritaria</p>
        </a>

        <!-- Coverage -->
        <a href="/contacto/zonas-de-cobertura/" class="group bg-white border border-[#e2e8f0] p-10 rounded-[40px] hover:shadow-2xl transition-all duration-500 text-center">
          <div class="size-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-6 group-hover:bg-[#155ec0] transition-colors">
            <MapIcon className="size-8 text-[#155ec0] group-hover:text-white" />
          </div>
          <h4 class="text-xl font-black text-[#061a36] mb-2">Área de Cobertura</h4>
          <p class="text-slate-500 font-bold">Bogotá y Sabana</p>
        </a>
      </div>

      <!-- Cobertura Map Bogotá (Sin modificar el fondo claro del main) -->
      <div class="mt-24 bg-white rounded-[48px] overflow-hidden border border-[#e2e8f0] h-[500px] relative group shadow-2xl">
        <div class="absolute inset-0 bg-[#061a36]/5 pointer-events-none z-10"></div>
        <img 
          src="/images/mapa_bogota.png" 
          alt="Mapa de Bogotá D.C. - VitalHome Salud" 
          class="w-full h-full object-cover transition-all duration-1000 opacity-60 group-hover:opacity-100 group-hover:scale-110"
        />
        <div class="absolute inset-0 flex items-center justify-center z-20 pointer-events-none">
          <div class="size-[400px] border-2 border-blue-400/30 rounded-full animate-pulse flex items-center justify-center bg-blue-400/5 backdrop-blur-[2px]">
            <div class="size-[200px] border border-blue-400/50 rounded-full flex items-center justify-center">
              <div class="size-4 bg-blue-400 rounded-full shadow-[0_0_20px_#60a5fa] animate-bounce"></div>
            </div>
          </div>
        </div>

        <div class="absolute inset-x-0 bottom-0 p-8 md:p-16 z-30 bg-gradient-to-t from-white via-white/95 to-transparent">
          <div class="flex flex-col md:flex-row justify-between items-end gap-8">
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <span class="size-3 rounded-full bg-blue-600 animate-ping"></span>
                <h5 class="text-2xl font-black text-[#011633] uppercase tracking-tight">Radio de Cobertura VitalHome</h5>
              </div>
              <p class="text-[#011633]/60 font-bold text-sm md:text-base uppercase tracking-[0.2em]">Bogotá D.C. • Chía • Cajicá • Zipaquirá • Sabana Norte</p>
            </div>
            <div class="flex flex-col gap-4">
              <div class="bg-[#061a36] text-white px-10 py-5 rounded-2xl font-black text-[12px] uppercase tracking-widest shadow-2xl border border-white/10 flex items-center gap-3">
                 <MapPin className="size-5" /> Cobertura Activa 24/7
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
